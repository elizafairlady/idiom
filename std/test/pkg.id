package test

use std/enum

export defrules test do
  (_ name body) -> %`{:test %,name (fn _ig %,body)}
end

export defmacro suite stx do
  defn parts-of do
    i n _body when (eq? i n) -> '()
    i n body -> cons (syntax-nth body i) (parts-of (add i 1) n body)
  end
  body = syntax-nth stx 2
  body-form? = and (syntax-list? body) (gt? (syntax-length body) 0) (syntax-word? (syntax-nth body 0)) (eq? (syntax-word-text (syntax-nth body 0)) "%-body")
  cond body-form? %`(run-suite (list %,@(parts-of 1 (syntax-length body) body))) %`(run-suite %,body)
end

export defn assert do
  :false -> error {:assert-failed :false}
  :nil -> error {:assert-failed :nil}
  v -> :ok
end

export defn assert-eq do
  a b when (eq? a b) -> :ok
  a b -> error {:assert-eq :got a :want b}
end

export defn assert-neq do
  a b when (neq? a b) -> :ok
  a b -> error {:assert-neq a b}
end

export defn assert-inspect do
  v expected when (eq? (inspect v) expected) -> :ok
  v expected -> error {:assert-inspect :got (inspect v) :want expected}
end

export defn assert-raises thunk do
  caught = try do
    thunk :go
    :no-raise
    rescue r -> {:raised r}
  end
  match caught do
    {:raised r} -> r
    _ -> error {:assert-raises :nothing-raised}
  end
end

export defn assert-expand-error do
  source expected -> match (expand-check source) do
    {:error {:expand msg}} ->
      cond (str-contains? msg expected) :ok (error {:assert-expand-error :got msg :want expected})
    :ok -> error {:assert-expand-error :compiled source}
  end
end

export defn assert-compiles do
  source -> match (expand-check source) do
    :ok -> :ok
    {:error {:expand msg}} -> error {:assert-compiles :failed msg :source source}
  end
end

defn run-one do
  {:test name thunk} failures -> do
    parent = self
    spawn (fn do
      outcome = try do
        thunk :go
        :ok
        rescue r -> {:failed r}
      end
      send parent {:test-outcome outcome}
    end)
    outcome = receive do
      {:test-outcome o} -> o
    end
    match outcome do
      :ok -> failures
      {:failed r} -> do
        "FAIL ${name}: #{inspect r}" |> println
        add failures 1
      end
    end
  end
end

defn run-all do
  '() failures total -> {failures total}
  (list t . rest) failures total -> run-all rest (run-one t failures) (add total 1)
end

export defn run-suite tests do
  result = run-all (tests.to-list) 0 0
  match result do
    {0 total} -> do
      "ok: ${total} tests" |> println
      :ok
    end
    {failures total} -> error {:suite-failed failures :of total}
  end
end

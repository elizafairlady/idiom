package runes

# Sorted closed intervals for zero-width combining/format code points.
# TODO: replace this legacy snapshot with a generated, Unicode-versioned table.
combining-ranges = {
  {768 879} {1155 1158} {1160 1161} {1425 1469} {1471 1471} {1473 1474}
  {1476 1477} {1479 1479} {1536 1539} {1552 1557} {1611 1630} {1648 1648}
  {1750 1764} {1767 1768} {1770 1773} {1807 1807} {1809 1809} {1840 1866}
  {1958 1968} {2027 2035} {2305 2306} {2364 2364} {2369 2376} {2381 2381}
  {2385 2388} {2402 2403} {2433 2433} {2492 2492} {2497 2500} {2509 2509}
  {2530 2531} {2561 2562} {2620 2620} {2625 2626} {2631 2632} {2635 2637}
  {2672 2673} {2689 2690} {2748 2748} {2753 2757} {2759 2760} {2765 2765}
  {2786 2787} {2817 2817} {2876 2876} {2879 2879} {2881 2883} {2893 2893}
  {2902 2902} {2946 2946} {3008 3008} {3021 3021} {3134 3136} {3142 3144}
  {3146 3149} {3157 3158} {3260 3260} {3263 3263} {3270 3270} {3276 3277}
  {3298 3299} {3393 3395} {3405 3405} {3530 3530} {3538 3540} {3542 3542}
  {3633 3633} {3636 3642} {3655 3662} {3761 3761} {3764 3769} {3771 3772}
  {3784 3789} {3864 3865} {3893 3893} {3895 3895} {3897 3897} {3953 3966}
  {3968 3972} {3974 3975} {3984 3991} {3993 4028} {4038 4038} {4141 4144}
  {4146 4146} {4150 4151} {4153 4153} {4184 4185} {4448 4607} {4959 4959}
  {5906 5908} {5938 5940} {5970 5971} {6002 6003} {6068 6069} {6071 6077}
  {6086 6086} {6089 6099} {6109 6109} {6155 6157} {6313 6313} {6432 6434}
  {6439 6440} {6450 6450} {6457 6459} {6679 6680} {6912 6915} {6964 6964}
  {6966 6970} {6972 6972} {6978 6978} {7019 7027} {7616 7626} {7678 7679}
  {8203 8207} {8234 8238} {8288 8291} {8298 8303} {8400 8431} {12330 12335}
  {12441 12442} {43014 43014} {43019 43019} {43045 43046} {64286 64286} {65024 65039}
  {65056 65059} {65279 65279} {65529 65531} {68097 68099} {68101 68102} {68108 68111}
  {68152 68154} {68159 68159} {119143 119145} {119155 119170} {119173 119179} {119210 119213}
  {119362 119364} {917505 917505} {917536 917631} {917760 917999}
}

spec combining-range-count :: int
defn combining-range-count -> 142

spec in? :: int int int -> atom
defn in? cp lo hi -> and (gte? cp lo) (lte? cp hi)

spec combining-search :: int int int -> atom
defn combining-search cp lo hi do
  if (gte? lo hi) do
    :false
  else do
    mid = (lo + hi) // 2
    {rlo rhi} = tuple-get combining-ranges mid
    if (lt? cp rlo) do
      combining-search cp lo mid
    else if (lte? cp rhi) do
      :true
    else do
      combining-search cp (add mid 1) hi
    end
  end
end

spec combining? :: int -> atom
defn combining? cp -> combining-search cp 0 combining-range-count

spec wide? :: int -> atom
defn wide? cp ->
  and (gte? cp 4352)
      (or (lte? cp 4447)
          (eq? cp 9001)
          (eq? cp 9002)
          (and (in? cp 11904 42191) (neq? cp 12351))
          (in? cp 44032 55203)
          (in? cp 63744 64255)
          (in? cp 65040 65049)
          (in? cp 65072 65135)
          (in? cp 65280 65376)
          (in? cp 65504 65510)
          (in? cp 127744 128591)
          (in? cp 128768 129023)
          (in? cp 129648 129791)
          (in? cp 131072 196605)
          (in? cp 196608 262141))

spec char-width :: int -> int
export defn char-width do
  0 -> 0
  cp when (combining? cp) -> 0
  cp when (wide? cp) -> 2
  _ -> 1
end

spec width-runes :: list int -> int
defn width-runes do
  '() acc -> acc
  '(cp . t) acc -> width-runes t (add acc (char-width cp))
end

spec width :: string -> int
export defn width s -> width-runes (str-to-list s) 0

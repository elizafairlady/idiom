use std/test
activate Test

suite do
  test "protocol activation and trait implementation compose" do
    got = do
      protocol QOps do
        operator <*!> precedence: 50 assoc: left capture: :infix do
          a b -> mul a b
        end
      end
      trait QSize do
        method qsize x
      end
      activate QOps
      implement QSize on int do
        method qsize n -> 11
      end
      {(qsize 3) (3 <*!> 4)}
    end
    assert-inspect got "{11 12}"
  end
  test "implement works against a declared trait" do
    got = do
      trait R do
        method tagit x
      end
      before = implements? R "x"
      implement R on string do
        method tagit s -> :str
      end
      {before (implements? R "x") (tagit "x")}
    end
    assert-inspect got "{:false :true :str}"
  end
  test "trait method default accepts direct do body" do
    trait DirectMethod do
      method show x do
        str "m:" x
      end
    end
    implement DirectMethod on int
    assert-eq (show 42) "m:42"
  end
  test "trait method default accepts direct multi-clause body" do
    trait DirectMultiMethod do
      method pick do
        x -> x
        _x y -> y
      end
    end
    implement DirectMultiMethod on int
    assert-inspect {(pick 4) (pick 4 9) (4.pick) (4.pick 9)} "{4 9 4 9}"
  end
  test "implement method accepts direct multi-clause body" do
    trait ImplMultiMethod do
      method pick do
        x -> x
        x y -> x + y
      end
    end
    implement ImplMultiMethod on int do
      method pick do
        x -> x
        x y -> x * y
      end
    end
    assert-inspect {(pick 4) (pick 4 9) (4.pick) (4.pick 9)} "{4 36 4 36}"
  end
  test "implement method arity set must match trait contract" do
    assert-expand-error "trait NarrowImpl do\n  method pick do\n    x -> x\n    x y -> y\n  end\nend\nimplement NarrowImpl on int do\n  method pick x -> x\nend" "arity mismatch"
  end
  test "implements? resolves trait names hygienically" do
    got = do
      trait R do
        method marker x -> :outer
      end
      outer-before = implements? R 1
      implement R on int
      outer-after = implements? R 1
      inner = do
        trait R do
          method marker x -> :inner
        end
        implements? R 1
      end
      {outer-before outer-after inner (marker 1)}
    end
    assert-inspect got "{:false :true :false :outer}"
  end
  test "trait and protocol declarations roll back outside their block" do
    assert-expand-error "do\n  trait S do\n    method sz x\n  end\n  :ok\nend\nsz 1" "unbound identifier 'sz'"
    assert-expand-error "do\n  protocol Shellp do\n    operator <!!> precedence: 50 assoc: left capture: :infix do\n      a b -> a\n    end\n  end\n  :ok\nend\n1 <!!> 2" "unbound identifier"
  end
  test "dispatch-cache-does-not-misserve-across-types" do
    trait Tag do method tag x end
    implement Tag on int do method tag x -> :int end
    implement Tag on string do method tag x -> :str end
    defn at x -> x.tag
    assert-eq (at 1) :int
    assert-eq (at "a") :str
    assert-eq (at 2) :int
    assert-eq (at "b") :str
  end
end

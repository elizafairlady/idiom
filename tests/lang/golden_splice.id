use std/test
activate Test

suite do
  test "qq-splice" do
    got = do
      xs = '(1 2 3); `(a ,@xs z)
    end
    assert-inspect got "(a 1 2 3 z)"
  end
  test "splice-flatt-capture" do
    got = do
      x = 40
      defmacro m %`(m %,name %,slot) -> do
        %`(do
            defn %,name v do
                %,slot = :other
                x
              end
          end)
      end
      m probe x
      probe 0
    end
    assert-inspect got "40"
  end
  test "splice-flatt-dual" do
    got = do
      defmacro m2 %`(m2 %,name %,slot) -> do
        %`(do
            defn %,name v do
                %,slot = 7
                add %,slot 1
              end
          end)
      end
      m2 probe2 y
      probe2 0
    end
    assert-inspect got "8"
  end
  test "splice-import" do
    got = do
      use tests/pkg/splicemak
      activate SpliceMak
      defdouble dbl
      dbl 21
    end
    assert-inspect got "42"
  end
  test "splice-isolation" do
    got = do
      defmacro defconst %`(defconst %,name %,value) -> do
        %`(do
            defn %,name v -> %,value
          end)
      end
      defconst a 1
      defconst b 2
      {(a 0) (b 0)}
    end
    assert-inspect got "{1 2}"
  end
  test "splice-publish" do
    got = do
      defmacro defzero %`(defzero %,name) -> do
        %`(do
            defn %,name v -> v
            defn helper99 -> 1
          end)
      end
      defzero published
      published 42
    end
    assert-inspect got "42"
  end
end

use std/test
implement std/test

suite do
  test "qq-splice" do
    got = do
      xs = [1 2 3]; `(a ,@xs z)
    end
    assert-inspect got "(a 1 2 3 z)"
  end
  test "splice-flatt-capture" do
    got = do
      x = 40
      defmacro m stx do
        %`(do
            defn %,(syntax-nth stx 2) v -> do
                %,(syntax-nth stx 3) = :other
                x
              end
          end)
      end
      m probe x
      probe 0
    end
    assert-inspect got "40"
  end
  test "splice-flatt-dual" do
    got = do
      defmacro m2 stx do
        %`(do
            defn %,(syntax-nth stx 2) v -> do
                %,(syntax-nth stx 3) = 7
                add %,(syntax-nth stx 3) 1
              end
          end)
      end
      m2 probe2 y
      probe2 0
    end
    assert-inspect got "8"
  end
  test "splice-import" do
    got = do
      implement tests/pkg/splicemak
      defdouble dbl
      dbl 21
    end
    assert-inspect got "42"
  end
  test "splice-isolation" do
    got = do
      defmacro defconst stx do
        %`(do
            defn %,(syntax-nth stx 2) v -> %,(syntax-nth stx 3)
          end)
      end
      defconst a 1
      defconst b 2
      tuple (a 0) (b 0)
    end
    assert-inspect got "{1 2}"
  end
  test "splice-publish" do
    got = do
      defmacro defzero stx do
        %`(do
            defn %,(syntax-nth stx 2) v -> v
            defn helper99 -> 1
          end)
      end
      defzero published
      published 42
    end
    assert-inspect got "42"
  end
end

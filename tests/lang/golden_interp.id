use std/test
activate std/test

suite do
  test "interp-cmd" do
    got = do
      activate std/shell
      "out:$(echo hi)"
    end
    assert-inspect got "\"out:hi\""
  end
  test "interp-escape" do
    got = do
      "lit \$ \#"
    end
    assert-inspect got "\"lit $ #\""
  end
  test "interp-expr-sub" do
    got = do
      "sum:$(add 1 2)"
    end
    assert-inspect got "\"sum:3\""
  end
  test "interp-expr" do
    got = do
      x = 20; "sum #{x + 22}"
    end
    assert-inspect got "\"sum 42\""
  end
  test "interp-multi" do
    got = do
      a = 3; b = 4; "#{a}+#{b}=#{a + b}"
    end
    assert-inspect got "\"3+4=7\""
  end
  test "interp-var" do
    got = do
      name = "world"; "hello ${name}"
    end
    assert-inspect got "\"hello world\""
  end
end

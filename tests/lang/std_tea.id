use std/test
activate Test
use std/tea

record Counter do
  field n
end

implement Model on Counter do
  method init _model -> emit :started
  method update model msg -> match msg do
    :inc -> {(Counter (model.n + 1)) (none)}
    {:add k} -> {(Counter (model.n + k)) (emit {:added k})}
    :many -> {model (batch (list (emit :a) (emit :b)))}
    :ordered -> {model (sequence (list (emit :first) (emit :second)))}
    :done -> {model (quit)}
    _ -> {model (none)}
  end
  method view model -> "count:${model.n}"
end

suite do
  test "model-trait-step" do
    {model cmd} = step (Counter 1) :inc
    assert-eq model.n 2
    assert-eq cmd (none)
    {model2 cmd2} = step model {:add 5}
    assert-eq model2.n 7
    assert-inspect (command-messages cmd2) "({:added 5})"
  end

  test "program-start-drain-and-view" do
    p = start (Counter 0)
    assert-eq p.model.view "count:0"
    assert-inspect p.pending "(:started)"
    p2 = drain p
    assert-eq p2.status :running
    assert-eq p2.model.view "count:0"
    assert-inspect p2.pending "()"
  end

  test "batch-and-sequence-commands" do
    assert-inspect (command-messages (batch (list (emit :a) (none) (emit :b)))) "(:a :b)"
    assert-inspect (command-messages (sequence (list (emit :first) (emit :second)))) "(:first :second)"
  end

  test "run-messages-drains-command-messages" do
    p = start (Counter 0)
    p2 = run-messages p (list :inc {:add 4})
    assert-eq p2.model.n 5
    assert-eq p2.model.view "count:5"
    assert-inspect p2.pending "()"
  end

  test "quit-command-halts-program" do
    p = run-messages (start (Counter 0)) (list :done :inc)
    assert-eq p.status :quit
    assert-eq p.model.n 0
  end
end

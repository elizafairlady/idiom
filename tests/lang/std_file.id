use std/test
activate std/test
use std/file
use std/enum

suite do
  test "file-roundtrip" do
    p = "/tmp/idiom_test_file_rt"
    assert-eq (write p "contents") :ok
    assert-eq (read! p) "contents"
    assert-eq (p |> write! "second") :ok
    assert-eq (read p) {:ok "second"}
    assert-eq (exists? p) :true
    assert-eq (remove p) :ok
    assert-eq (exists? p) :false
    assert-inspect (remove p) "{:error :enoent}"
  end
  test "file-errors-tagged" do
    assert-inspect (read "/tmp/idiom_no_such_file") "{:error :enoent}"
    r = assert-raises (fn do read! "/tmp/idiom_no_such_file" end)
    assert-eq (r |> tuple-get 0) :error
    r2 = assert-raises (fn do write! "/tmp/idiom_no_such_parent/x" "data" end)
    assert-eq r2 {:error {:file-write "/tmp/idiom_no_such_parent/x" :enoent}}
  end
  test "file-stat" do
    p = "/tmp/idiom_test_stat"
    write! p "12345"
    s = match (stat p) do
      {:ok st} -> st
    end
    assert-eq (s |> tuple-get 1) :file
    assert-eq (s |> tuple-get 2) 5
    assert (gte? (mtime! p) 0)
    assert-eq (dir? "/tmp") :true
    assert-eq (dir? p) :false
    remove p
  end
  test "file-mkdir" do
    d = "/tmp/idiom_test_mkdir"
    remove d
    assert-eq (mkdir d) :ok
    assert-eq (dir? d) :true
    assert-inspect (mkdir d) "{:error :eexist}"
    assert-eq (remove d) :ok
    assert-eq (d |> mkdir!) :ok
    r = assert-raises (fn do mkdir! d end)
    assert-eq r {:error {:file-mkdir d :eexist}}
    assert-inspect (mkdir "/tmp/idiom_no_such_parent/x") "{:error :enoent}"
    remove d
  end
  test "file-mkdir-p" do
    base = "/tmp/idiom_test_mkdir_p"
    assert-eq (mkdir-p (str base "/a/b/c")) :ok
    assert-eq (dir? (str base "/a/b/c")) :true
    assert-eq (mkdir-p (str base "/a/b/c")) :ok
    assert-eq (mkdir-p! (str base "/a/b")) :ok
    f = str base "/a/file"
    write! f "x"
    assert-inspect (mkdir-p f) "{:error :eexist}"
    r = assert-raises (fn do mkdir-p! f end)
    assert-eq r {:error {:file-mkdir f :eexist}}
    remove f
    remove (str base "/a/b/c")
    remove (str base "/a/b")
    remove (str base "/a")
    assert-eq (remove base) :ok
  end
  test "file-append" do
    p = "/tmp/idiom_test_append"
    remove p
    assert-eq (append p "one") :ok
    assert-eq (p |> append "-two") :ok
    assert-eq (read! p) "one-two"
    assert-eq (append! p "-three") :ok
    assert-eq (read! p) "one-two-three"
    assert-inspect (append "/tmp/idiom_no_such_parent/x" "data") "{:error :enoent}"
    r = assert-raises (fn do append! "/tmp/idiom_no_such_parent/x" "data" end)
    assert-eq r {:error {:file-append "/tmp/idiom_no_such_parent/x" :enoent}}
    assert-eq (remove p) :ok
  end
  test "file-list" do
    p = "/tmp/idiom_test_dir_probe"
    write! p "x"
    names = match (ls "/tmp") do
      {:ok ns} -> ns
    end
    assert-eq (names.member? "idiom_test_dir_probe") :true
    remove p
  end
end

use std/test
activate Test
import std/file as File
use std/enum

defn collect-chunk chunk acc -> "#{acc}${chunk}"

suite do
  test "file-roundtrip" do
    p = "/tmp/idiom_test_file_rt"
    assert-eq (File.write p "contents") :ok
    assert-eq (File.read! p) "contents"
    assert-eq (p |> File.write! "second") :ok
    assert-eq (File.read p) {:ok "second"}
    assert-eq (File.exists? p) :true
    assert-eq (File.remove p) :ok
    assert-eq (File.exists? p) :false
    assert-inspect (File.remove p) "{:error :enoent}"
  end
  test "file-errors-tagged" do
    assert-inspect (File.read "/tmp/idiom_no_such_file") "{:error :enoent}"
    r = assert-raises (fn do File.read! "/tmp/idiom_no_such_file" end)
    assert-eq (r |> tuple-get 0) :error
    r2 = assert-raises (fn do File.write! "/tmp/idiom_no_such_parent/x" "data" end)
    assert-eq r2 {:error {:file-write "/tmp/idiom_no_such_parent/x" :enoent}}
  end
  test "stat" do
    p = "/tmp/idiom_test_stat"
    File.write! p "12345"
    s = match (File.stat p) do
      {:ok st} -> st
    end
    assert-eq (s |> tuple-get 1) :file
    assert-eq (s |> tuple-get 2) 5
    assert (gte? (File.mtime! p) 0)
    assert-eq (File.dir? "/tmp") :true
    assert-eq (File.dir? p) :false
    File.remove p
  end
  test "mkdir" do
    d = "/tmp/idiom_test_mkdir"
    File.remove d
    assert-eq (File.mkdir d) :ok
    assert-eq (File.dir? d) :true
    assert-inspect (File.mkdir d) "{:error :eexist}"
    assert-eq (File.remove d) :ok
    assert-eq (d |> File.mkdir!) :ok
    r = assert-raises (fn do File.mkdir! d end)
    assert-eq r {:error {:file-mkdir d :eexist}}
    assert-inspect (File.mkdir "/tmp/idiom_no_such_parent/x") "{:error :enoent}"
    File.remove d
  end
  test "file-mkdir-p" do
    base = "/tmp/idiom_test_mkdir_p"
    assert-eq (File.mkdir-p (str base "/a/b/c")) :ok
    assert-eq (File.dir? (str base "/a/b/c")) :true
    assert-eq (File.mkdir-p (str base "/a/b/c")) :ok
    assert-eq (File.mkdir-p! (str base "/a/b")) :ok
    f = str base "/a/file"
    File.write! f "x"
    assert-inspect (File.mkdir-p f) "{:error :eexist}"
    r = assert-raises (fn do File.mkdir-p! f end)
    assert-eq r {:error {:file-mkdir f :eexist}}
    File.remove f
    File.remove (str base "/a/b/c")
    File.remove (str base "/a/b")
    File.remove (str base "/a")
    assert-eq (File.remove base) :ok
  end
  test "append" do
    p = "/tmp/idiom_test_append"
    File.remove p
    assert-eq (File.append p "one") :ok
    assert-eq (p |> File.append "-two") :ok
    assert-eq (File.read! p) "one-two"
    assert-eq (File.append! p "-three") :ok
    assert-eq (File.read! p) "one-two-three"
    assert-inspect (File.append "/tmp/idiom_no_such_parent/x" "data") "{:error :enoent}"
    r = assert-raises (fn do File.append! "/tmp/idiom_no_such_parent/x" "data" end)
    assert-eq r {:error {:file-append "/tmp/idiom_no_such_parent/x" :enoent}}
    assert-eq (File.remove p) :ok
  end
  test "list" do
    p = "/tmp/idiom_test_dir_probe"
    File.write! p "x"
    names = match (File.ls "/tmp") do
      {:ok ns} -> ns
    end
    assert-eq (names.member? "idiom_test_dir_probe") :true
    File.remove p
  end
  test "file-port-read-fold-and-write" do
    p = "/tmp/idiom_test_chunks"
    File.remove p
    out = File.open! p :write
    assert (port? out)
    assert-eq (File.write-port-all out "abcdef") {:ok 6}
    assert-eq (File.close out) :ok
    assert-eq (port-status out) :done
    inp = File.open! p :read
    assert (port? inp)
    assert-eq (File.read-port inp 2) {:data "ab"}
    assert-eq (File.read-port inp 3) {:data "cde"}
    assert-eq (File.read-port inp 4) {:data "f"}
    assert-eq (File.read-port inp 4) :eof
    assert-eq (File.close inp) :ok
    assert-eq (port-status inp) :done
    folded = match (File.fold-chunks p 2 "" &collect-chunk) do
      {:ok data} -> data
    end
    assert-eq folded "abcdef"
    out2 = File.open! p :write
    assert-eq (File.write-port-all! out2 "z") {:ok 1}
    assert-eq (File.close out2) :ok
    assert-eq (File.read! p) "z"
    assert-inspect (File.open "/tmp/idiom_missing_chunk" :read) "{:error :enoent}"
    assert-eq (File.remove p) :ok
  end
end

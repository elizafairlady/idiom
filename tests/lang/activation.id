use std/test
use std/string
activate Test

suite do
  test "use imports runtime names with later-wins rebind" do
    got = do
      use tests/pkg/exporter
      use tests/pkg/exporter2
      {(who 0) (dbl 4)}
    end
    assert-inspect got "{:second 8}"
  end
  test "use does not activate macros" do
    assert-expand-error "use tests/pkg/exporter\nanswer 1" "unbound identifier 'answer'"
  end
  test "use does not activate operators" do
    assert-expand-error "use tests/pkg/exporter\n3 <+> 4" "unbound identifier"
  end
  test "use imports trait method surface but not conformance" do
    got = try do
      use tests/pkg/protomethod
      describe 1
      rescue r -> r
    end
    match got do
      {:error {:runtime msg}} -> assert (contains? msg "does not implement trait")
    end
  end
  test "implement activates macros and operators" do
    got = do
      use tests/pkg/exporter
      activate Exporter
      {(answer x) (3 <+> 4)}
    end
    assert-inspect got "{99 7}"
  end
  test "implement surface is scoped to its context" do
    assert-expand-error "use tests/pkg/exporter\ndo\n  activate Exporter\n  answer x\nend\nanswer x" "unbound identifier 'answer'"
    assert-expand-error "use tests/pkg/exporter\ndo\n  activate Exporter\nend\n3 <+> 4" "unbound identifier"
    got = do
      use tests/pkg/exporter
      activate Exporter
      do
        answer q
      end
    end
    assert-inspect got "99"
  end
  test "inner activation shadows outer by scope" do
    use tests/pkg/exporter
    use tests/pkg/exporter2
    activate Exporter
    inner = do
      activate Exporter2
      {(answer x) (3 <+> 4)}
    end
    assert-inspect {inner (answer x) (3 <+> 4)} "{{7 -1} 99 7}"
  end
  test "re-activating the same package is idempotent" do
    got = do
      use tests/pkg/exporter
      activate Exporter
      activate Exporter
      answer x
    end
    assert-inspect got "99"
  end
  test "two providers of one surface name in one context error" do
    assert-expand-error "use tests/pkg/exporter\nuse tests/pkg/exporter2\nactivate Exporter\nactivate Exporter2\nanswer x" "already active in this context"
  end
  test "provider-private helper beats consumer same-name binder" do
    got = do
      use tests/pkg/macropriv
      activate MacroPriv
      defn hidden x -> 1000
      inc-private 41
    end
    assert-inspect got "42"
  end
  test "import qualifies protocols without activation" do
    got = do
      import tests/pkg/exporter as E
      activate E.Exporter
      answer x
    end
    assert-inspect got "99"
    assert-expand-error "import tests/pkg/exporter as E\nE.answer x" "unbound identifier 'E'"
  end
end

use std/test
implement std/test

suite do
  test "arithmetic" do
    assert-eq (1 + 2 * 3) 7
    assert-eq (2 ** 10) 1024
  end
  test "clauses and patterns" do
    f = fn do
      0 -> :zero
      [h . _] -> tuple :head h
      _ -> :other
    end
    assert-eq (f 0) :zero
    assert-eq (f (list 9)) (tuple :head 9)
    assert-eq (f "x") :other
  end
  test "expansion errors" do
    assert-expand-error "no-such-z 1" "unbound identifier"
    assert-compiles "add 1 2"
  end
end

use std/test
activate Test

suite do
  test "scalars coerce: string, int, bool, null" do
    got = do
      use tests/pkg/yaml
      activate Yaml
      yaml
        name: "api"
        replicas: 3
        enabled: true
        empty: null
        plain: hello
    end
    assert-eq got %{:name "api" :replicas 3 :enabled :true :empty :nil :plain "hello"}
  end

  test "nested mappings and sequences" do
    got = do
      use tests/pkg/yaml
      activate Yaml
      yaml
        name: "api"
        ports: [80 443]
        metadata:
          owner: "platform"
          active: false
    end
    assert-eq got %{:name "api" :ports '(80 443) :metadata %{:owner "platform" :active :false}}
  end

  test "sequence of mappings" do
    got = do
      use tests/pkg/yaml
      activate Yaml
      yaml
        servers: [%{ name: "api" ports: [80 443] } %{ name: "web" ports: [8080] }]
    end
    assert-eq got %{:servers '(%{:name "api" :ports (80 443)} %{:name "web" :ports (8080)})}
  end

  test "the body is read by idiom, validated by core syntax" do
    assert-expand-error "use tests/pkg/yaml\nactivate Yaml\nyaml\n" "yaml expects a single mapping body"
  end
end

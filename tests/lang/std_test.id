use std/test
activate std/test

suite do
  test "assertion-helpers" do
    assert :true
    assert-eq (assert-raises (fn do assert :false end)) {:error {:assert-failed :false}}
    assert-eq (assert-raises (fn do assert :nil end)) {:error {:assert-failed :nil}}
    assert-eq 1 1
    assert-eq (assert-raises (fn do assert-eq 1 2 end)) {:error {:assert-eq :got 1 :want 2}}
    assert-neq 1 2
    assert-eq (assert-raises (fn do assert-neq 1 1 end)) {:error {:assert-neq 1 1}}
    assert-inspect {:ok 1} "{:ok 1}"
    assert-eq (assert-raises (fn do assert-inspect :x ":y" end)) {:error {:assert-inspect :got ":x" :want ":y"}}
    assert-eq (assert-raises (fn do error :boom end)) {:error :boom}
    assert-eq (assert-raises (fn do assert-raises (fn -> :ok) end)) {:error {:assert-raises :nothing-raised}}
  end

  test "compile-assertions-and-nested-run-suite" do
    assert-compiles "1 + 2"
    assert-expand-error "missing-binding" "unbound identifier"
    assert-eq (run-suite (list (test "nested-zero-arity" do assert-eq 2 2 end))) :ok
  end
end

use std/test
activate std/test
use tests/pkg/netstring

suite do
  test "parse single netstrings" do
    assert-eq (parse-one "5:hello,") {:ok "hello"}
    assert-eq (parse-one "0:,") {:ok ""}
    assert-eq (parse-one "5:a,b:c,") {:ok "a,b:c"}
  end

  test "parse repeated netstrings" do
    assert-eq (parse-all "5:hello,0:,6:world!,") {:ok '("hello" "" "world!")}
    assert-eq (parse-all (emit-all '("a" "bc" ""))) {:ok '("a" "bc" "")}
  end

  test "return next offset for embedding" do
    assert-eq (parse-one-at "3:one,3:two," 0) {:ok {"one" 6}}
    assert-eq (parse-one-at "3:one,3:two," 6) {:ok {"two" 12}}
  end

  test "reject invalid netstrings" do
    assert-eq (parse-one ":abc,") {:error {:netstring :empty-length 0}}
    assert-eq (parse-one "x:abc,") {:error {:netstring :bad-length-byte 0 120}}
    assert-eq (parse-one "4:abc") {:error {:netstring :truncated 2 4 5}}
    assert-eq (parse-one "4:abc,") {:error {:netstring :missing-comma 6}}
    assert-eq (parse-one "1:a,1:b,") {:error {:netstring :trailing 4}}
  end
end

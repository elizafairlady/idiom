use std/test
activate Test
use std/regex

defn triple x -> x * 3

suite do
  test "regex-result survives cross-actor copy" do
    parent = self
    spawn (fn do
      r = scan r"a(b+)c" "xxabbbc"
      send parent {(text-of r) (capture r 1)}
    end)
    assert-eq (receive do m -> m end) {"abbbc" "bbb"}
  end

  test "closure with package binding survives cross-actor copy" do
    parent = self
    worker = spawn (fn do
      f = receive do m -> m end
      send parent (f 14)
    end)
    send worker (fn do x -> triple x end)
    assert-eq (receive do m -> m end) 42
  end

  test "boxed float and nested structure survive cross-actor copy" do
    parent = self
    worker = spawn (fn do
      v = receive do m -> m end
      send parent v
    end)
    send worker {2.5 [1.5 9] "hi" :nil}
    assert-eq (receive do m -> m end) {2.5 [1.5 9] "hi" :nil}
  end
end

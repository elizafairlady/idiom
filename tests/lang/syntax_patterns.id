use std/test
activate Test

defmacro plus-two %`(plus-two %,x) -> %`(add %,x 2)

defmacro syntax-list do
  %`(syntax-list %,@xs) -> %`(list %,@xs)
end

defmacro installed-syntax-macro do
  %`(installed-syntax-macro %,x) -> %`(add %,x 4)
end

protocol SyntaxCore do
  core-syntax syntax-core-add do
    %`(syntax-core-add %,x %,y) -> %`(add %,x %,y)
  end

  core-syntax syntax-core-list do
    %`(syntax-core-list %,@xs) -> %`(list %,@xs)
  end
end

activate SyntaxCore

suite do
  test "match accepts quasisyntax patterns" do
    got = match %`(add 1 2) do
      %`(sub %,a %,b) -> :bad
      %`(add %,a %,b) -> {(syntax-int-value a) (syntax-int-value b)}
    end
    assert-eq got {1 2}
  end

  test "repeated quasisyntax binders compare structurally" do
    assert-eq (match %`(same 1 1) do %`(same %,x %,x) -> :same; _ -> :different end) :same
    assert-eq (match %`(same 1 2) do %`(same %,x %,x) -> :same; _ -> :different end) :different
    assert-eq (match %`(both (1 2) (1 2)) do %`(both (%,@xs) (%,@xs)) -> :same; _ -> :different end) :same
    assert-eq (match %`(both (1 2) (1 3)) do %`(both (%,@xs) (%,@xs)) -> :same; _ -> :different end) :different
  end

  test "quasisyntax dict patterns are keyed" do
    got = match %`%{:b 2 :a 1 :c 3} do
      %`%{:a %,x . %,rest} -> {(syntax-int-value x) (syntax-length rest)}
    end
    assert-eq got {1 4}

    duplicate = match %`%{:a 1 :a 2 :b 3} do
      %`%{:a %,x . %,rest} -> {(syntax-int-value x) (syntax-length rest)}
    end
    assert-eq duplicate {2 2}

    assert-eq (match %`%{:a 1 :b 2} do %`%{:a %,x} -> syntax-int-value x; _ -> :bad end) 1
  end

  test "defmacro accepts quasisyntax parameter" do
    assert-eq (plus-two 40) 42
  end

  test "defmacro accepts quasisyntax clauses" do
    assert-eq (syntax-list 1 2 3) '(1 2 3)
  end

  test "defmacro accepts quasisyntax clauses after another macro" do
    assert-eq (installed-syntax-macro 38) 42
  end

  test "core syntax accepts quasisyntax clauses" do
    assert-eq {(syntax-core-add 20 22) (syntax-core-list 1 2 3)} {42 '(1 2 3)}
  end
end

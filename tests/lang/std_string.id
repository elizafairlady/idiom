use std/test
activate std/test
use std/enum
use std/string

suite do
  test "string-basics" do
    assert-eq ("hello" |> length) 5
    assert-eq ("hello" |> empty?) :false
    assert-eq ("hello" |> slice 1 4) "ell"
    assert-eq ("hello" |> at 1) 101
    assert-eq ("banana" |> find "na" 0) 2
    assert-eq ("banana" |> find "zz" 0) :nil
    assert-eq ("banana" |> contains? "nan") :true
    assert-eq ("banana" |> contains? "zz") :false
    assert-eq ("idiom" |> starts-with? "idi") :true
    assert-eq ("idiom" |> ends-with? "om") :true
  end
  test "string-lookup-misses" do
    assert-eq ("abc" |> at 9) :nil
    assert-eq ("ab" |> starts-with? "abc") :false
    assert-eq ("ab" |> ends-with? "xab") :false
    assert-eq (assert-raises (fn do "hello" |> slice 2 9 end)) {:error {:slice-out-of-range 2 9 5}}
    assert-eq (assert-raises (fn do "hello" |> slice (neg 1) 3 end)) {:error {:slice-out-of-range (neg 1) 3 5}}
    assert-eq (assert-raises (fn do "hello" |> slice 3 2 end)) {:error {:slice-out-of-range 3 2 5}}
  end
  test "string-trim" do
    assert-eq ("  x  " |> trim) "x"
    assert-eq ("\t a" |> trim-left) "a"
    assert-eq ("a \n" |> trim-right) "a"
    assert-eq ("x" |> blank?) :false
    assert-eq ("" |> blank?) :true
  end
  test "string-split-join" do
    assert-inspect ("a:b:c" |> split ":") "(\"a\" \"b\" \"c\")"
    assert-eq ((list "a" "b" "c") |> join "-") "a-b-c"
    assert-eq ("::x::" |> split "::" |> join "|") "|x|"
    assert-eq ("a\nb\n" |> lines) '("a" "b" "")
    assert-eq (assert-raises (fn do "abc" |> split "" end)) {:error {:split :empty-separator}}
  end
  test "string-replace-repeat-pad" do
    assert-eq ("banana" |> replace "na" "NA") "baNANA"
    assert-eq ("ab" |> repeat 3) "ababab"
    assert-eq ("ab" |> repeat 0) ""
    assert-eq ("7" |> pad-left 3 "0") "007"
    assert-eq ("7" |> pad-right 3 "!") "7!!"
    assert-eq ("wide" |> pad-left 2 "0") "wide"
  end
  test "string-case" do
    assert-eq ("Mixed Case 9" |> upcase) "MIXED CASE 9"
    assert-eq ("Mixed Case 9" |> downcase) "mixed case 9"
    assert-eq ("" |> capitalize) ""
    assert-eq ("9lives" |> capitalize) "9lives"
  end
  test "string-expanded-surface" do
    assert-eq ("" |> empty?) :true
    assert-eq (" \t\n" |> blank?) :true
    assert-eq ("idiom" |> find-from "i" 1) 2
    assert-eq ("  x" |> trim-leading) "x"
    assert-eq ("x  " |> trim-trailing) "x"
    assert-eq ("a\nb" |> split-lines) '("a" "b")
    assert-eq ("hé" |> chars) '(104 233)
    assert-eq ("hé" |> runes) '(104 233)
    assert-eq ("abc" |> reverse) "cba"
    assert-eq ("hé" |> first) 104
    assert-eq ("" |> first) :nil
    assert-eq ("hé" |> first!) 104
    assert-eq (assert-raises (fn do "" |> first! end)) {:error {:empty-string}}
    assert-eq ("hé" |> last) 233
    assert-eq ("" |> last) :nil
    assert-eq ("hé" |> last!) 233
    assert-eq (assert-raises (fn do "" |> last! end)) {:error {:empty-string}}
    assert-eq ("héllo" |> take 2) "hé"
    assert-eq ("héllo" |> take 99) "héllo"
    assert-eq ("héllo" |> take (neg 1)) ""
    assert-eq ("héllo" |> drop 2) "llo"
    assert-eq ("héllo" |> drop 99) ""
    assert-eq ("héllo" |> drop (neg 1)) "héllo"
    assert-eq ("héllo" |> slice-runes 1 4) "éll"
    assert-eq ("héllo" |> slice-runes 4 99) "o"
    assert-eq ("hELLO" |> capitalize) "Hello"
  end
  test "string-enumerable-as-runes" do
    assert-eq "abc".to-list '(97 98 99)
    assert-eq "".to-list '()
    assert-eq ("abc".map (fn b -> b + 1)) '(98 99 100)
    assert-eq "abc".sum 294
    assert-eq "hé".to-list '(104 233)
    assert-eq "héllo".to-list '(104 233 108 108 111)
    assert-eq (byte-str 233).to-list '(65533)
    assert-eq "#{byte-str 233}a".to-list '(65533 97)
    assert-eq ("héllo" |> len) 6
    assert-eq ("héllo" |> byte 1) 195
  end
  test "rune-string-conversions" do
    assert-eq (ord->str 233) "é"
    assert-eq (ord->str 97) "a"
    assert-eq (ord->str 128512 |> str->ord) 128512
    assert-eq (ord->str 128512 |> len) 4
    assert-eq (str->ord "héllo") 104
    assert-eq (str->ord "é") 233
    assert-eq (str->ord "") :nil
    assert-eq (str->ord (byte-str 233)) 65533
    assert-eq (from-runes '(104 233 108 108 111)) "héllo"
    assert-eq (from-runes "héllo".to-list) "héllo"
    assert-eq (from-runes '()) ""
    assert-inspect (assert-raises (fn do ord->str 55296 end)) "{:error {:type-error :ord->str 55296}}"
    assert-inspect (assert-raises (fn do ord->str (neg 1) end)) "{:error {:type-error :ord->str -1}}"
    assert-inspect (assert-raises (fn do ord->str 1114112 end)) "{:error {:type-error :ord->str 1114112}}"
    assert-eq (assert-raises (fn do from-runes '(104 55296) end)) {:error {:type-error :from-runes 55296}}
    assert-eq (assert-raises (fn do from-runes "x" end)) {:error {:type-error :from-runes "x"}}
  end
  test "parse-int-whole-string" do
    assert-eq ("42" |> parse-int) {:ok 42}
    assert-eq ("-17" |> parse-int) {:ok -17}
    assert-eq ("+5" |> parse-int) {:ok 5}
    assert-eq (parse-int "9223372036854775807") {:ok 9223372036854775807}
    assert-eq (parse-int "-9223372036854775808") {:ok -9223372036854775808}
    assert-inspect (parse-int "") "{:error {:parse :int \"\"}}"
    assert-inspect (parse-int " 42") "{:error {:parse :int \" 42\"}}"
    assert-inspect (parse-int "42 ") "{:error {:parse :int \"42 \"}}"
    assert-inspect (parse-int "42x") "{:error {:parse :int \"42x\"}}"
    assert-inspect (parse-int "4.2") "{:error {:parse :int \"4.2\"}}"
    assert-inspect (parse-int "0x10") "{:error {:parse :int \"0x10\"}}"
    assert-inspect (parse-int "9223372036854775808") "{:error {:parse :int \"9223372036854775808\"}}"
    assert-inspect (parse-int "-9223372036854775809") "{:error {:parse :int \"-9223372036854775809\"}}"
    assert-eq ("42" |> parse-int!) 42
    assert-eq (assert-raises (fn do "nope" |> parse-int! end)) {:error {:parse :int "nope"}}
    assert-eq (assert-raises (fn do parse-int :nope end)) {:error {:type-error :parse-int :nope}}
  end
  test "parse-float-whole-string" do
    assert-eq ("2.5" |> parse-float) {:ok 2.5}
    assert-eq (parse-float "-0.25") {:ok -0.25}
    assert-eq (parse-float "1e3") {:ok 1000.0}
    assert-eq (parse-float ".5") {:ok 0.5}
    assert-eq (parse-float "7") {:ok 7.0}
    assert-eq (parse-float "nan") {:ok :nan}
    assert-eq (parse-float "inf") {:ok :inf}
    assert-inspect (parse-float "") "{:error {:parse :float \"\"}}"
    assert-inspect (parse-float " 2.5") "{:error {:parse :float \" 2.5\"}}"
    assert-inspect (parse-float "2.5x") "{:error {:parse :float \"2.5x\"}}"
    assert-inspect (parse-float "1e") "{:error {:parse :float \"1e\"}}"
    assert-eq ("2.5" |> parse-float!) 2.5
    assert-eq (assert-raises (fn do "x" |> parse-float! end)) {:error {:parse :float "x"}}
  end
end

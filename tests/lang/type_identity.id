use std/test
use tests/pkg/point_a
import tests/pkg/point_b as B
activate Test

record Local do
  field n :: int
end

suite do
  test "is-a? resolves the target in its own package" do
    own? (make 1) |> assert-eq :true
    B.own? (B.make 2 3) |> assert-eq :true
    own? (B.make 4 5) |> assert-eq :false
    B.own? (make 6) |> assert-eq :false
  end

  test "is-a? resolves the target at the use site" do
    is-a? (make 7) :Point |> assert-eq :true
    is-a? (B.make 8 9) :Point |> assert-eq :false
    is-a? (Local 10) :Point |> assert-eq :false
    is-a? (Local 11) :Local |> assert-eq :true
  end
end

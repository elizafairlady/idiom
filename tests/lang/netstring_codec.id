use std/test
activate Test
use tests/pkg/netstring
activate Netstring

suite do
  test "encode via the Codec trait" do
    assert-eq (encode "hello") "5:hello,"
    assert-eq (encode "") "0:,"
    assert-eq "a,b:c".encode "5:a,b:c,"
  end

  test "the << operator frames a stream" do
    assert-eq ("" << "a" << "bc" << "") "1:a,2:bc,0:,"
  end

  test "decode a single netstring" do
    assert-eq (decode "5:hello,") {:ok "hello"}
    assert-eq (decode "0:,") {:ok ""}
    assert-eq (decode "5:a,b:c,") {:ok "a,b:c"}
  end

  test "decode-all round-trips the << stream" do
    assert-eq (decode-all "5:hello,0:,6:world!,") {:ok '("hello" "" "world!")}
    assert-eq (decode-all ("" << "a" << "bc" << "")) {:ok '("a" "bc" "")}
  end

  test "decode-at returns the next offset for embedding" do
    assert-eq (decode-at "3:one,3:two," 0) {:ok {"one" 6}}
    assert-eq (decode-at "3:one,3:two," 6) {:ok {"two" 12}}
  end

  test "reject malformed netstrings" do
    assert-eq (decode ":abc,") {:error {:netstring :empty-length 0}}
    assert-eq (decode "x:abc,") {:error {:netstring :bad-length-byte 0 120}}
    assert-eq (decode "4:abc") {:error {:netstring :truncated 2 4 5}}
    assert-eq (decode "4:abc,") {:error {:netstring :missing-comma 6}}
    assert-eq (decode "1:a,1:b,") {:error {:netstring :trailing 4}}
  end
end

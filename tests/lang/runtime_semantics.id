use std/test
activate std/test
use std/enum

suite do
  test "integer-overflow-traps" do
    assert-eq (assert-raises (fn do 9223372036854775807 + 1 end)) {:error {:overflow :add}}
    assert-eq (assert-raises (fn do 0 - 9223372036854775807 - 2 end)) {:error {:overflow :sub}}
    assert-eq (assert-raises (fn do 4611686018427387904 * 4 end)) {:error {:overflow :mul}}
    assert-eq (assert-raises (fn do 2 ** 64 end)) {:error {:overflow :pow}}
    int-min = 0 - 9223372036854775807 - 1
    assert-eq (assert-raises (fn do neg int-min end)) {:error {:overflow :neg}}
    assert-eq (assert-raises (fn do int-min / -1 end)) {:error {:overflow :div}}
    assert-eq (assert-raises (fn do int-min % -1 end)) {:error {:overflow :mod}}
    assert-eq (assert-raises (fn do int-min // -1 end)) {:error {:overflow :floor-div}}
    assert-eq (assert-raises (fn do abs int-min end)) {:error {:overflow :abs}}
  end
  test "floor-division-operators" do
    assert-eq (-7 // 2) -4
    assert-eq (-7 %% 2) 1
    assert-eq (-7 / 2) -3
    assert-eq (-7 % 2) -1
    assert-eq (1 + -7 // 2 * 2) -7
    assert-eq (assert-raises (fn do 1 // 0 end)) {:error {:div-by-zero :floor-div}}
    assert-eq (assert-raises (fn do 1 %% 0 end)) {:error {:div-by-zero :floor-mod}}
  end
  test "int64-boundary-literals" do
    assert-eq 9223372036854775807 (9223372036854775806 + 1)
    assert-eq -9223372036854775808 (0 - 9223372036854775807 - 1)
    assert-inspect 9223372036854775807 "9223372036854775807"
    assert-inspect -9223372036854775808 "-9223372036854775808"
  end
  test "negative-literals-after-open-delimiters" do
    assert-eq {-3 -1} {(neg 3) (neg 1)}
    assert-eq [-3 -1] [(neg 3) (neg 1)]
    assert-eq %{-3 :x -1 :y} %{(neg 3) :x (neg 1) :y}
    assert-eq (-3 + 1) -2
    assert-eq '(-3 -1) (list (neg 3) (neg 1))
  end
  test "one-arithmetic" do
    assert-eq (1 + 2.5) 3.5
    assert-eq (add 1 2.5) 3.5
    assert-eq ((list 1 2.5) |> apply &add) 3.5
    assert-eq (2.0 * 2) 4.0
    assert-eq (1.5 < 2) :true
    assert-eq (lte? 2 2.0) :true
    assert-eq (gt? 2.5 2) :true
    assert-eq (gte? 2 2.5) :false
    assert-eq (1 == 1.0) :false
  end
  test "error-shapes" do
    assert-eq (assert-raises (fn do add 1 :nope end)) {:error {:type-error :add 1 :nope}}
    assert-eq (assert-raises (fn do 1 < :nope end)) {:error {:type-error :lt? 1 :nope}}
    assert-eq (assert-raises (fn do 1 / 0 end)) {:error {:div-by-zero :div}}
    assert-eq (assert-raises (fn do 1 % 0 end)) {:error {:div-by-zero :mod}}
    assert-eq (assert-raises (fn do first :nope end)) {:error {:type-error :first :nope}}
    assert-eq (assert-raises (fn do (list 1) |> apply 5 end)) {:error {:not-callable 5}}
    assert-eq (assert-raises (fn do (list "a" "b") |> apply &str-len end)) {:error {:arity :str-len 2 1 1}}
    assert-eq (assert-raises (fn do tuple-get {1 2} 5 end)) {:error {:index-out-of-range 5}}
    got = assert-raises (fn do
      defn just-one 1 -> :one
      just-one 2
    end)
    assert-eq got {:error {:no-clause :just-one {2}}}
  end
  test "error-macro-arities" do
    assert-eq (assert-raises (fn do error :bad end)) {:error :bad}
    assert-eq (assert-raises (fn do error :bad 42 end)) {:error {:bad 42}}
    got = try do
      error :code 7 :extra
      :unreached
      rescue r -> match r do
        {:error {:code n more}} -> {n more}
      end
    end
    assert-eq got {7 :extra}
  end
  test "guard-raise-and-ensure-semantics" do
    assert-eq (try do
      41
      ensure 99
    end) 41
    captured = try do
      raise :boom
      rescue r -> (fn _go -> r) :go
    end
    assert-eq captured :boom
    assert-eq (try do
      (list :applied) |> apply &raise
      rescue r -> r
    end) :applied
    assert-eq (try do
      try do
        raise :body
        rescue r -> raise {:handler r}
        ensure raise :cleanup
      end
      rescue r -> r
    end) :cleanup
  end
  test "type-predicates-and-is-a" do
    record Box do
      field v
    end
    b = Box 7
    raw = make-record "Box" (dict :v 8)
    word_value = syntax->datum %'word
    assert-eq {(nil? :nil) (atom? :a) (word? word_value) (int? 1) (float? 1.0) (string? "x") (pair? '(1)) (empty-list? '()) (list? '(1 2)) (tuple? {1}) (vector? [1]) (dict? %{:a 1}) (syntax? %'word) (closure? (fn x -> x)) (primitive? &add) (record? b)} {:true :true :true :true :true :true :true :true :true :true :true :true :true :true :true :true}
    assert-eq {(cell? :x) (pid? self) (ref? :x) (port? :x) (regex? :x) (regex-result? :x)} {:false :true :false :false :false :false}
    assert-eq {(is-a? 1 :int) (is-a? 1 "int") (is-a? '(1 2) :list) (is-a? (cons 1 2) :list) (is-a? '(1 2) :pair) (is-a? '() :empty-list)} {:true :true :true :false :true :true}
    assert-eq {(is-a? b :record) (is-a? b (record-type b)) (is-a? raw (record-type raw)) (is-a? raw (record-type b)) (Box? b) (Box? raw)} {:true :true :true :false :true :false}
  end
  test "zero-arity-defn-reference-calls" do
    defn answer -> 42
    assert-eq answer 42
  end
  test "zero-arity-local-function-binding-reference-calls" do
    f = fn -> 9
    assert-eq f 9
  end
  test "zero-arity-captured-binding-reference-calls" do
    make = fn _tag do
      f = fn -> 11
      fn _go -> f
    end
    thunk = make :ready
    assert-eq (thunk :go) 11
  end
  test "float-prints-distinguishably" do
    assert-inspect 1.0 "1.0"
    assert-inspect 2.5 "2.5"
    assert-inspect (neg 2.0) "-2.0"
    assert-inspect (2.0 * 2) "4.0"
    assert-inspect (1.0 / 2) "0.5"
    assert-inspect 1 "1"
  end
  test "dict-equality-structural" do
    assert-eq %{:a 1 :b 2} %{:b 2 :a 1}
    m = %{:a 1 :b 2}
    assert-eq m (dict-put m :a (dict-get m :a :nil))
    assert-neq %{:a 1} %{:a 1 :b 2}
    assert-neq %{:a 1} %{:a 2}
    assert-inspect (dict-put %{:a 1 :b 2} :a 9) "%{:a 9 :b 2}"
  end
  test "strings-byte-storage-rune-iteration" do
    assert-eq (str-len "héllo") 6
    assert-eq (str-byte "é" 0) 195
    assert-eq (str-byte "é" 1) 169
    assert-eq "abc".to-list '(97 98 99)
    assert-eq "".to-list '()
    assert-inspect "é".to-list "(233)"
  end
  test "tail-call-constant-stack" do
    got = do
      defn count do
        0 -> :done
        n -> count (n - 1)
      end
      count 1000000
    end
    assert-inspect got ":done"
  end
  test "tail-call-alternating-clauses" do
    got = do
      defn parity do
        0 :even -> :even
        0 :odd -> :odd
        n p -> parity (n - 1) (cond (eq? p :even) :odd :even)
      end
      parity 100001 :even
    end
    assert-inspect got ":odd"
  end
  test "guard-budget-bounded" do
    got = assert-raises (fn do
      defn spin-guard n -> spin-guard n
      defn pick do
        n when (spin-guard n) -> n
      end
      pick 1
    end)
    match got do
      {:error {:runtime msg}} -> assert (str-contains? msg "exceeded its budget")
    end
  end
  test "trait-implement-sequential-rebind" do
    got = do
      trait Tag do
        method tag x
      end
      implement Tag on int do
        method tag _n -> :first
      end
      implement Tag on int do
        method tag _n -> :second
      end
      tag 1
    end
    assert-inspect got ":second"
  end
  test "tail-method-dispatch" do
    got = do
      trait Down do
        method down n -> cond (eq? n 0) :done (down (n - 1))
      end
      implement Down on int
      down 200000
    end
    assert-inspect got ":done"
  end
end

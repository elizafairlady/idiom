use std/test
activate std/test
use std/enum

suite do
  test "integer-overflow-traps" do
    assert-eq (assert-raises (fn _ig do 9223372036854775807 + 1 end)) {:error {:overflow :add}}
    assert-eq (assert-raises (fn _ig do 0 - 9223372036854775807 - 2 end)) {:error {:overflow :sub}}
    assert-eq (assert-raises (fn _ig do 4611686018427387904 * 4 end)) {:error {:overflow :mul}}
    assert-eq (assert-raises (fn _ig do 2 ** 64 end)) {:error {:overflow :pow}}
    int-min = 0 - 9223372036854775807 - 1
    assert-eq (assert-raises (fn _ig do neg int-min end)) {:error {:overflow :neg}}
    assert-eq (assert-raises (fn _ig do int-min / -1 end)) {:error {:overflow :div}}
    assert-eq (assert-raises (fn _ig do int-min % -1 end)) {:error {:overflow :mod}}
    assert-eq (assert-raises (fn _ig do int-min // -1 end)) {:error {:overflow :floor-div}}
    assert-eq (assert-raises (fn _ig do abs int-min end)) {:error {:overflow :abs}}
  end
  test "floor-division-operators" do
    assert-eq (-7 // 2) -4
    assert-eq (-7 %% 2) 1
    assert-eq (-7 / 2) -3
    assert-eq (-7 % 2) -1
    assert-eq (1 + -7 // 2 * 2) -7
    assert-eq (assert-raises (fn _ig do 1 // 0 end)) {:error {:div-by-zero :floor-div}}
    assert-eq (assert-raises (fn _ig do 1 %% 0 end)) {:error {:div-by-zero :floor-mod}}
  end
  test "int64-boundary-literals" do
    assert-eq 9223372036854775807 (9223372036854775806 + 1)
    assert-eq -9223372036854775808 (0 - 9223372036854775807 - 1)
    assert-inspect 9223372036854775807 "9223372036854775807"
    assert-inspect -9223372036854775808 "-9223372036854775808"
  end
  test "one-arithmetic" do
    assert-eq (1 + 2.5) 3.5
    assert-eq (add 1 2.5) 3.5
    assert-eq (apply &add (list 1 2.5)) 3.5
    assert-eq (2.0 * 2) 4.0
    assert-eq (1.5 < 2) :true
    assert-eq (lte? 2 2.0) :true
    assert-eq (gt? 2.5 2) :true
    assert-eq (gte? 2 2.5) :false
    assert-eq (1 == 1.0) :false
  end
  test "error-shapes" do
    assert-eq (assert-raises (fn _ig do add 1 :nope end)) {:error {:type-error :add 1 :nope}}
    assert-eq (assert-raises (fn _ig do 1 < :nope end)) {:error {:type-error :lt? 1 :nope}}
    assert-eq (assert-raises (fn _ig do 1 / 0 end)) {:error {:div-by-zero :div}}
    assert-eq (assert-raises (fn _ig do 1 % 0 end)) {:error {:div-by-zero :mod}}
    assert-eq (assert-raises (fn _ig do first :nope end)) {:error {:type-error :first :nope}}
    assert-eq (assert-raises (fn _ig do apply 5 (list 1) end)) {:error {:not-callable 5}}
    assert-eq (assert-raises (fn _ig do apply &str-len (list "a" "b") end)) {:error {:arity :str-len 2 1 1}}
    assert-eq (assert-raises (fn _ig do tuple-get {1 2} 5 end)) {:error {:index-out-of-range 5}}
    got = assert-raises (fn _ig do
      defn just-one 1 -> :one
      just-one 2
    end)
    assert-eq got {:error {:no-clause :just-one {2}}}
  end
  test "error-macro-arities" do
    assert-eq (assert-raises (fn _ig do error :bad end)) {:error :bad}
    assert-eq (assert-raises (fn _ig do error :bad 42 end)) {:error {:bad 42}}
    got = try do
      error :code 7 :extra
      :unreached
      rescue r -> match r do
        {:error {:code n more}} -> {n more}
      end
    end
    assert-eq got {7 :extra}
  end
  test "zero-arity-defn-reference-calls" do
    defn answer -> 42
    assert-eq answer 42
  end
  test "zero-arity-local-function-binding-reference-calls" do
    f = fn -> 9
    assert-eq f 9
  end
  test "zero-arity-captured-binding-reference-calls" do
    make = fn _tag do
      f = fn -> 11
      fn _go -> f
    end
    thunk = make :ready
    assert-eq (thunk :go) 11
  end
  test "float-prints-distinguishably" do
    assert-inspect 1.0 "1.0"
    assert-inspect 2.5 "2.5"
    assert-inspect (neg 2.0) "-2.0"
    assert-inspect (2.0 * 2) "4.0"
    assert-inspect (1.0 / 2) "0.5"
    assert-inspect 1 "1"
  end
  test "dict-equality-structural" do
    assert-eq %{:a 1 :b 2} %{:b 2 :a 1}
    m = %{:a 1 :b 2}
    assert-eq m (dict-put m :a (dict-get m :a :nil))
    assert-neq %{:a 1} %{:a 1 :b 2}
    assert-neq %{:a 1} %{:a 2}
    assert-inspect (dict-put %{:a 1 :b 2} :a 9) "%{:a 9 :b 2}"
  end
  test "strings-byte-storage-rune-iteration" do
    assert-eq (str-len "héllo") 6
    assert-eq (str-byte "é" 0) 195
    assert-eq (str-byte "é" 1) 169
    assert-eq "abc".to-list '(97 98 99)
    assert-eq "".to-list '()
    assert-inspect "é".to-list "(233)"
  end
  test "tail-call-constant-stack" do
    got = do
      defn count do
        0 -> :done
        n -> count (n - 1)
      end
      count 1000000
    end
    assert-inspect got ":done"
  end
  test "tail-call-alternating-clauses" do
    got = do
      defn parity do
        0 :even -> :even
        0 :odd -> :odd
        n p -> parity (n - 1) (cond (eq? p :even) :odd :even)
      end
      parity 100001 :even
    end
    assert-inspect got ":odd"
  end
  test "guard-budget-bounded" do
    got = assert-raises (fn _ig do
      defn spin-guard n -> spin-guard n
      defn pick do
        n when (spin-guard n) -> n
      end
      pick 1
    end)
    match got do
      {:error {:runtime msg}} -> assert (str-contains? msg "exceeded its budget")
    end
  end
  test "trait-implement-sequential-rebind" do
    got = do
      trait Tag do
        method tag x
      end
      implement Tag on int do
        method tag _n -> :first
      end
      implement Tag on int do
        method tag _n -> :second
      end
      tag 1
    end
    assert-inspect got ":second"
  end
  test "tail-method-dispatch" do
    got = do
      trait Down do
        method down n -> cond (eq? n 0) :done (down (n - 1))
      end
      implement Down on int
      down 200000
    end
    assert-inspect got ":done"
  end
end

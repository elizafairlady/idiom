use std/test
activate std/test
use tests/pkg/yaml

suite do
  test "parse flat map scalars" do
    source = "name: api\nreplicas: 3\nenabled: true\nempty: null\n"
    assert-eq (parse source) {:ok %{"name" "api" "replicas" 3 "enabled" :true "empty" :nil}}
  end

  test "parse nested maps and sequences" do
    source = "name: api\nports:\n  - 80\n  - 443\nmetadata:\n  owner: platform\n  active: false\n"
    assert-eq (parse source) {:ok %{"name" "api" "ports" '(80 443) "metadata" %{"owner" "platform" "active" :false}}}
  end

  test "parse sequence of maps from dash payload indentation" do
    source = "servers:\n  - name: api\n    ports:\n      - 80\n      - 443\n  - name: web\n    ports:\n      - 8080\n"
    expected = %{"servers" '(%{"name" "api" "ports" (80 443)} %{"name" "web" "ports" (8080)})}
    assert-eq (parse source) {:ok expected}
  end

  test "ignore blank lines and full-line comments" do
    source = "# deployment\n\nname: \"api\"\n# service ports\nports:\n  - 'http'\n  - https\n"
    assert-eq (parse source) {:ok %{"name" "api" "ports" '("http" "https")}}
  end

  test "reject malformed indentation and entries" do
    assert-eq (parse "a: 1\n  b: 2\n") {:error {:yaml :unexpected-indent 2 2 "b: 2"}}
    assert-eq (parse "a:\nb: 1\n") {:error {:yaml :missing-child 1}}
    assert-eq (parse ": 1\n") {:error {:yaml :empty-key 1}}
    assert-eq (parse "\tbad: 1\n") {:error {:yaml :tab-indent 1}}
  end
end

use std/test
use std/string
activate Test

defn kadd2 a b -> add a b
defmacro twice2 %`(twice2 %,e) -> %`(kadd2 %,e %,e)

defmacro my-or do
  %`(my-or %,a %,b) -> %`(do
    tmp = %,a
    cond tmp tmp %,b
  end)
end

defmacro destr-pair do
  %`(destr-pair %,e) -> %`(do
    {hxa hxb} = %,e
    add hxa hxb
  end)
end

defmacro destr-list do
  %`(destr-list %,e) -> %`(do
    '(lha . lht) = %,e
    {lha lht}
  end)
end

defmacro destr-vec do
  %`(destr-vec %,e) -> %`(do
    '(lva lvb) = vector-to-list %,e
    add lva lvb
  end)
end

defmacro inc2 do
  %`(inc2 %,a) -> %`(add %,a 1)
end

defmacro leaf3 s3 -> make-syntax-int s3 7

defmacro nest3 do
  %`(nest3 %,n) -> do
    v = syntax-int-value n
    if (eq? v 0) do
      %`0
    else do
      %`(do
        x = %,(make-syntax-int n v)
        add x (nest3 %,(make-syntax-int n (sub v 1)))
      end)
    end
  end
end

defmacro ping2 do
  %`(ping2 %,n) -> do
    v = syntax-int-value n
    if (eq? v 0) do
      %`:done
    else do
      %`(do
        p = :ping
        {p (pong2 %,(make-syntax-int n (sub v 1)))}
      end)
    end
  end
end
defmacro pong2 do
  %`(pong2 %,n) -> do
    v = syntax-int-value n
    if (eq? v 0) do
      %`:done
    else do
      %`(do
        p = :pong
        {p (ping2 %,(make-syntax-int n (sub v 1)))}
      end)
    end
  end
end

defmacro with-it2 do
  %`(with-it2 %,v %,b) -> do
    it = bind! v "it"
    %`(do
      %,it = %,v
      %,b
    end)
  end
end

defmacro swapif do
  %`(swapif %,c %,a %,b) when (syntax-int? c) -> %`(cond (gt? %,c 0) %,a %,b)
  %`(swapif %,c %,a %,b) -> %`(cond %,c %,a %,b)
end

defmacro defproto2 %`(defproto2 %,n %,b) -> %`do
  protocol %,n %,b
end
defmacro deftrait2 %`(deftrait2 %,n %,b) -> %`do
  trait %,n %,b
end
defproto2 Greets2 do
  export defmacro answer2 s -> (make-syntax-int s 99)
end
deftrait2 Sized2 do
  method size-of2 x -> mul x 10
end

defmacro defrec2 %`(defrec2 %,n %,b) -> %`do
  record %,n %,b
end
defrec2 Pt2 do
  field x
end

defmacro bring do
  %`(bring %,v) -> %`(do
    use tests/pkg/exporter
    activate Exporter
    {(answer q) (%,v <+> 1)}
  end)
end

defmacro letpair do
  %`(letpair %,a %,b %,body) -> %`do
    %,a = 10
    %,b = 20
    %,body
  end
end

defmacro defsz do
  %`(defsz %,p %,m) -> %`do
    trait %,p do
      method %,m x -> mul x 10
    end
  end
end
defsz Sz3 szof3

defmacro defext do
  %`(defext %,t %,p %,m) -> %`do
    implement %,p on %,t do
      method %,m x -> :spliced-impl
    end
  end
end
trait Zp do
  method zz x
end
defext int Zp zz

for-syntax do
  defmacro forty s -> make-syntax-int s 40
  defmacro two s -> make-syntax-int s 2
end

for-syntax do
  defn pick-fs x -> 1
end
for-syntax do
  defn pick-fs x -> 2
end
defmacro which-fs stx -> make-syntax-int stx (pick-fs 0)

suite do
  test "or/tmp swap does not capture caller tmp" do
    got = do
      tmp = :user
      {(my-or :nil tmp) (my-or tmp 99)}
    end
    assert-inspect got "{:user :user}"
  end
  test "phase macro declarations remain available" do
    assert-eq (leaf3 q) 7
  end
  test "recursive macro introducing a binder each round" do
    got = do
      x = 1000
      {(nest3 4) x}
    end
    assert-inspect got "{10 1000}"
  end
  test "mutually recursive macros leave caller p untouched" do
    got = do
      p = :user
      {(ping2 3) p}
    end
    assert-inspect got "{{:ping {:pong {:ping :done}}} :user}"
  end
  test "library macro template add resolves at definition site" do
    got = do
      defn kadd2 a b -> :inner-shadow
      twice2 21
    end
    assert-eq got 42
  end
  test "declared macro ignores caller add shadow" do
    got = do
      defn add a b -> :user-add
      inc2 41
    end
    assert-eq got 42
  end
  test "match survives caller shadowing if/cond/tuple/raise" do
    got = do
      defn if a b c -> :user-if
      defn cond a b c -> :user-cond
      defn tuple a b -> :user-tuple
      defn raise x -> :user-raise
      match 5 do
        5 -> :matched
        _ -> :other
      end
    end
    assert-eq got :matched
  end
  test "bind! deliberately captures caller it" do
    got = do
      it = :outer
      with-it2 10 (add it 5)
    end
    assert-eq got 15
  end
  test "bind! introduced name visible only through template" do
    assert-eq (with-it2 10 (add it 5)) 15
  end
  test "bind! capture consistent in bind-RHS position" do
    got = do
      it = :outer
      r = with-it2 10 (add it 5)
      {r it}
    end
    assert-inspect got "{15 :outer}"
  end
  test "package macro template uses sibling exported macro" do
    got = do
      use tests/pkg/sibmac
      activate SibMac
      doubled q
    end
    assert-eq got 42
  end
  test "import alias resolves record identity in implement" do
    got = do
      trait AliasView2 do
        method ashow2 x
      end
      import tests/pkg/boxa as Q
      b = Q.box 7
      implement AliasView2 on Q.box do
        method ashow2 v -> Q.unbox v
      end
      ashow2 b
    end
    assert-eq got 7
  end
  test "import alias bindings stay in the importing block" do
    assert-expand-error "do\n  import tests/pkg/exporter as E\n  E.answer x\nend\nE.answer x\n" "unbound identifier 'E'"
  end
  test "macro clause guard sees library predicate not caller shadow" do
    got = do
      defn gt? a b -> :false
      swapif 5 :pos :nonpos
    end
    assert-eq got :pos
  end
  test "macro clause runtime branch on non-literal" do
    got = do
      c = :nil
      swapif c :t :f
    end
    assert-eq got :f
  end
  test "macro-spliced protocol exports a macro" do
    got = do
      activate Greets2
      answer2 foo
    end
    assert-eq got 99
  end
  test "macro-spliced trait method with default body" do
    got = do
      implement Sized2 on int do
        method size-of2 x -> 100
      end
      size-of2 5
    end
    assert-eq got 100
  end
  test "macro-spliced record" do
    got = do
      p = Pt2 7
      {p.x (Pt2? p)}
    end
    assert-inspect got "{7 :true}"
  end
  test "macro template activates implement and operator" do
    assert-inspect (bring 6) "{99 7}"
  end
  test "sibling diamond activations stay independent" do
    got = do
      use tests/pkg/exporter
      use tests/pkg/exporter2
      activate Exporter
      a = do
        activate Exporter2
        {(answer x) (3 <+> 4)}
      end
      b = do
        activate Exporter2
        {(answer x) (3 <+> 4)}
      end
      {a b (answer x) (3 <+> 4)}
    end
    assert-inspect got "{{7 -1} {7 -1} 99 7}"
  end
  test "user binders threaded through a macro body" do
    assert-eq (letpair p q (add p q)) 30
  end
  test "macro-defined trait with literal method default" do
    got = do
      implement Sz3 on int
      szof3 4
    end
    assert-eq got 40
  end
  test "spliced implement installs a method" do
    assert-eq (zz 5) :spliced-impl
  end
  test "defmacro pair from one for-syntax block" do
    assert-eq (add (forty x) (two x)) 42
  end
  test "later for-syntax definition wins (same phase rebind)" do
    assert-eq (which-fs q) 2
  end
  test "use binds runtime slots into its block" do
    got = do
      use tests/pkg/exporter
      dbl 21
    end
    assert-eq got 42
  end
  test "provider operator target unaffected by caller shadow" do
    got = do
      use tests/pkg/exporter
      activate Exporter
      defn add a b -> :nope
      3 <+> 4
    end
    assert-eq got 7
  end
  test "package macro clauses expand ignoring caller mul shadow" do
    got = do
      use tests/pkg/rulespkg
      activate RulesPkg
      defn mul a b -> :shadow
      twice-of 21
    end
    assert-eq got 42
  end
  test "package core syntax ignores caller str/append shadows" do
    got = do
      use tests/pkg/htmldsl
      activate HtmlDsl
      defn str a -> :shadow
      defn append a b -> :shadow
      span :class "x" "hi"
    end
    assert-eq got "<span class=\"x\">hi</span>"
  end
  test "import alias qualifies protocols without activation" do
    got = do
      import tests/pkg/exporter as E
      activate E.Exporter
      answer x
    end
    assert-eq got 99
  end
  test "implement inside fn body active for its runtime extent" do
    got = do
      mk = fn do
        use tests/pkg/exporter
        activate Exporter
        fn x -> x <+> (answer q)
      end
      f = mk
      f 1
    end
    assert-eq got 100
  end
  test "re-implement is idempotent" do
    got = do
      use tests/pkg/exporter
      activate Exporter
      activate Exporter
      answer x
    end
    assert-eq got 99
  end
  test "block defmacro invisible outside even via re-emitting macro" do
    assert-expand-error "defmacro emit stx -> %`(blockm q)\ndo\n  defmacro blockm stx -> make-syntax-int stx 5\n  blockm q\nend\nemit x" "unbound identifier 'blockm'"
  end
  test "block operator invisible outside its block" do
    assert-expand-error "do\n  operator <**> precedence: 50 assoc: left capture: :infix -> add\n  1 <**> 2\nend\n1 <**> 2" "unbound identifier '<**>'"
  end
  test "macro-introduced names not visible after splice" do
    assert-expand-error "defmacro m stx -> %`(do\n    defn hidden-fn v -> v\n  end)\nm x\nhidden-fn 1\n" "unbound identifier 'hidden-fn'"
  end
  test "macro operator with caller name is visible" do
    got = do
      defmacro install-op stx -> match stx do
        %`(install-op %,name) -> %`do
          operator %,name precedence: 50 assoc: left capture: :infix -> add
        end
      end
      install-op <++>
      40 <++> 2
    end
    assert-eq got 42
  end
  test "macro-invented core operator name is hygienic" do
    assert-expand-error "defmacro install-op stx -> %`do\n  core-operator <++> 50 \"left\" \"infix\" add\nend\ninstall-op x\n40 <++> 2\n" "unbound identifier '<++>'"
  end
  test "two providers of one surface in one context collide" do
    assert-expand-error "use tests/pkg/exporter\nuse tests/pkg/exporter2\nactivate Exporter\nactivate Exporter2\nanswer x" "already active in this context"
  end
  test "two same-named traits from packages collide on use" do
    assert-expand-error "use tests/pkg/sizea\nuse tests/pkg/sizeb\nsize 5" "already active in this context"
  end
  test "use does not activate macros" do
    assert-expand-error "use tests/pkg/exporter\nanswer 1" "unbound identifier 'answer'"
  end
  test "for-syntax helper absent at runtime" do
    assert-expand-error "for-syntax do\n  defn helper x -> x\nend\nhelper 1\n" "unbound identifier 'helper'"
  end
  test "runtime helper absent for-syntax" do
    assert-expand-error "defn helper x -> x\ndefmacro m stx -> helper stx\nm 1\n" "unbound identifier 'helper'"
  end
  test "transformer lexical fn-capture still rejected cleanly" do
    assert-expand-error "outerv = 10\ndefmacro m stx -> make-syntax-int stx outerv\nm 5" "unbound identifier 'outerv'"
  end
  test "dispatch error names qualified trait identity" do
    got = do
      trait Qx do
        method probe-q x
      end
      implement Qx on string do
        method probe-q s -> :str
      end
      try do
        probe-q 5
        rescue r -> r
      end
    end
    match got do
      {:error {:runtime msg}} -> assert (contains? msg "Qx#")
    end
  end
  test "macro-introduced pattern bind does not capture" do
    hxa = 50
    got = destr-pair {hxa 2}
    assert-eq got 52
    assert-eq hxa 50
    hxb = my-or :nil (destr-pair {hxa hxa})
    assert-eq hxb 100
  end
  test "macro-introduced list and vector patterns are hygienic" do
    lha = 70
    lht = 71
    got = destr-list '(1 2 3)
    assert-eq got {1 '(2 3)}
    assert-eq {lha lht} {70 71}
    got2 = destr-vec [40 2]
    assert-eq got2 42
  end
  test "list pattern head is recognized by name even when shadowed" do
    list = fn a b -> [a b]
    '(pa pb) = '(8 9)
    assert-eq (add pa pb) 17
    assert-eq (list 1 2) [1 2]
  end
end

use std/test
activate std/test

suite do
  test "guard-defn-eq" do
    got = do
      defn g n when n == 42 -> 42; defn g n -> 0; g 42
    end
    assert-inspect got "42"
  end
  test "guard-defn" do
    got = do
      defn f n when n < 0 -> 0; defn f n -> n; f 42
    end
    assert-inspect got "42"
  end
  test "guard-match" do
    got = do
      match 7 do n when n < 10 -> 42; _ -> 0 end
    end
    assert-inspect got "42"
  end
  test "guard-recv" do
    got = do
      send self 5; receive do n when n > 10 -> 0; n -> add n 37 end
    end
    assert-inspect got "42"
  end
  test "guard-reads-captured-local-and-pattern-var" do
    got = do
      expected = 7
      send self {:v 7}
      receive do {:v n} when (eq? n expected) -> :match; {:v _} -> :mismatch; after 200 -> :timeout end
    end
    assert-inspect got ":match"
  end
end

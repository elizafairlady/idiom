use std/test
activate std/test

suite do
  test "op-div" do
    got = do
      84 / 2
    end
    assert-inspect got "42"
  end
  test "op-func-target" do
    got = do
      defn combine a b -> add (mul a 10) b
      operator glue precedence: 50 assoc: left fixity: infix -> combine
      4 glue 2
    end
    assert-inspect got "42"
  end
  test "op-mod" do
    got = do
      142 % 100
    end
    assert-inspect got "42"
  end
  test "op-neg" do
    got = do
      50 + -8
    end
    assert-inspect got "42"
  end
  test "glued-minus-argument" do
    got = do
      f = fn a b do {a b} end
      f 1 -2
    end
    assert-inspect got "{1 -2}"
  end
  test "glued-minus-vs-infix" do
    got = do
      f = fn a b do {a b} end
      raised = match (assert-raises (fn _ig do f 1 - 2 end)) do {:error _} -> :applied-one-arg end
      x = 10
      {raised (x - 1) (2 * -3)}
    end
    assert-inspect got "{:applied-one-arg 9 -6}"
  end
  test "glued-minus-no-spaces-is-ident" do
    assert-expand-error "x-1" "unbound identifier 'x-1'"
  end
  test "op-neq" do
    got = do
      cond (3 != 4) 42 0
    end
    assert-inspect got "42"
  end
  test "op-pow-right" do
    got = do
      2 ** 3 ** 2
    end
    assert-inspect got "512"
  end
  test "op-pow" do
    got = do
      2 ** 5 + 10
    end
    assert-inspect got "42"
  end
  test "op-prefix-neg-bind" do
    got = do
      x = -5; x + 47
    end
    assert-inspect got "42"
  end
  test "op-symbolic-name" do
    got = do
      defn combine a b -> add (mul a 10) b
      operator <+> precedence: 50 assoc: left fixity: infix -> combine
      1 <+> 2 <+> 3
    end
    assert-inspect got "123"
  end
end

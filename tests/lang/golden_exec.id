use std/test

suite do
  test "exec-actor-cwd" do
    got = do
      implements std/shell
      cd "/tmp"
      "in:$(env pwd)"
    end
    assert-inspect got "\"in:/tmp\""
  end
  test "exec-capture" do
    got = do
      implements std/shell
      out = printf 42; out
    end
    assert-inspect got "{:ok 0 \"42\" \"\"}"
  end
  test "exec-error" do
    got = do
      implements std/shell
      out = ls /no/such/path/zzz; match out do {tag code so se} -> tag end
    end
    assert-inspect got ":error"
  end
  test "exec-pipeline" do
    got = do
      implements std/shell
      out = printf "a\nb\nc\n" | wc -l; match out do {tag code so se} -> so end
    end
    assert-inspect got "\"3\\n\""
  end
end

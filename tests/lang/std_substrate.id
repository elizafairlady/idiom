use std/test
use std/enum
use std/string
import std/list as L
import std/map as Map
import std/path as Path
import std/range as Range
import std/term as Term
import std/tea as Tea
activate Test

suite do
  test "list kernel operations share one behavior" do
    xs = '(1 2 3 4)
    L.reverse xs |> assert-eq '(4 3 2 1)
    L.concat-all '((1 2) (3) (4)) |> assert-eq '(1 2 3 4)
    xs |> L.map (fn x -> x * 2) |> assert-eq '(2 4 6 8)
    xs |> L.filter (fn x -> eq? (x %% 2) 0) |> assert-eq '(2 4)
    xs |> L.take 2 |> assert-eq '(1 2)
    xs |> L.drop 2 |> assert-eq '(3 4)
    xs |> L.split-at 2 |> assert-eq {'(1 2) '(3 4)}
    L.zip '(1 2) '(:a :b) |> assert-eq '({1 :a} {2 :b})
    L.intersperse '(1 2 3) :x |> assert-eq '(1 :x 2 :x 3)
    L.last xs |> assert-eq 4
  end

  test "enum sequence methods delegate to list surface" do
    [1 2 3].to-list |> assert-eq '(1 2 3)
    {1 2 3}.reverse |> assert-eq '(3 2 1)
    '(1 2 3 4).take-while (fn x -> lt? x 3) |> assert-eq '(1 2)
    [1 2 3 4].drop 2 |> assert-eq '(3 4)
    {1 2 3 4}.partition (fn x -> eq? (x %% 2) 0) |> assert-eq {'(2 4) '(1 3)}
    "abc".map (fn b -> b + 1) |> assert-eq '(98 99 100)
  end

  test "range remains one explicit range substrate" do
    r = Range.new 1 5
    implements? Enum r |> assert
    r.to-list |> assert-eq '(1 2 3 4)
    r.length |> assert-eq 4
    Range.inclusive 1 5 2 |> Range.to-list |> assert-eq '(1 3 5)
    Range.exclusive 5 1 -2 |> Range.to-list |> assert-eq '(5 3)
    Range.contains? (Range.inclusive 1 5 2) 3 |> assert-eq :true
    Range.contains? (Range.inclusive 1 5 2) 4 |> assert-eq :false
  end

  test "string rune operations use list helpers" do
    "héllo" |> reverse |> assert-eq "olléh"
    "héllo" |> take 2 |> assert-eq "hé"
    "héllo" |> drop 2 |> assert-eq "llo"
    "héllo" |> last |> assert-eq 111
    (list "a" "b" "c") |> join "-" |> assert-eq "a-b-c"
    "  x\n" |> trim |> assert-eq "x"
    " \t\n" |> blank? |> assert-eq :true
  end

  test "byte whitespace predicate is shared" do
    space? 32 |> assert-eq :true
    space? 13 |> assert-eq :true
    Term.space-byte? 13 |> assert-eq :true
    Term.filled-byte? 13 |> assert-eq :false
    Term.filled-byte? 65 |> assert-eq :true
  end

  test "map current exported surface is covered" do
    m = %{:a 1 :b 2}
    Map.get m :a |> assert-eq 1
    Map.get-or m :z 9 |> assert-eq 9
    Map.fetch m :b |> assert-eq {:ok 2}
    Map.fetch m :z |> assert-eq {:error {:key-not-found :z}}
    Map.has? m :a |> assert-eq :true
    Map.empty? %{} |> assert-eq :true
    m |> Map.put :c 3 |> Map.size |> assert-eq 3
    m |> Map.del :a |> assert-eq %{:b 2}
    m |> Map.update :a 0 (fn v -> v + 10) |> assert-eq %{:a 11 :b 2}
    Map.pop m :a |> assert-eq {1 %{:b 2}}
    Map.pop-result m :z |> assert-eq {:error {:key-not-found :z}}
  end

  test "path lexical helpers stay pure" do
    Path.join "/tmp" "x" |> assert-eq "/tmp/x"
    Path.join "/tmp/" "x" |> assert-eq "/tmp/x"
    Path.dirname "/tmp/x.txt" |> assert-eq "/tmp"
    Path.basename "/tmp/x.txt" |> assert-eq "x.txt"
    Path.extname "/tmp/x.txt" |> assert-eq ".txt"
    Path.extname "/tmp/.profile" |> assert-eq ""
    Path.absolute? "/tmp/x" |> assert-eq :true
    Path.absolute? "tmp/x" |> assert-eq :false
  end

  test "tea command batching uses std list fold order" do
    Tea.command-messages (Tea.batch (list (Tea.emit :a) (Tea.emit :b))) |> assert-eq '(:a :b)
    Tea.command-messages (Tea.sequence (list (Tea.emit :c) (Tea.emit :d))) |> assert-eq '(:c :d)
  end
end

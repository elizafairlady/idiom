use std/test
use std/map
use std/enum

suite do
  test "map-basics" do
    m = dict :a 1 :b 2
    assert-eq (m |> get :a) 1
    assert-eq (m |> get :zz) :nil
    assert-eq (m |> get-or :zz 9) 9
    assert-eq (m |> size) 2
    assert-eq (m |> has? :b) :true
  end
  test "map-update-pipeline" do
    m = dict |> put :n 1 |> update :n 0 (fn v -> add v 10) |> del :gone
    assert-eq (m |> get :n) 11
    assert-eq (m |> size) 1
  end
  test "map-merge-keys" do
    m = (dict :a 1) |> merge (dict :b 2 :a 9)
    assert-eq (m |> get :a) 9
    assert-eq (m |> keys |> length) 2
  end
end

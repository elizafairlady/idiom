use std/test
activate Test
import std/map as Map
use std/enum

suite do
  test "map-basics" do
    m = %{:a 1 :b 2}
    assert-eq (m |> Map.get :a) 1
    assert-eq (m |> Map.get :zz) :nil
    assert-eq (m |> Map.get-or :zz 9) 9
    assert-eq (m |> Map.size) 2
    assert-eq (m |> Map.has? :b) :true
    assert-eq (m |> Map.has? :z) :false
    assert-eq (Map.vals m).sort '(1 2)
    assert-eq (%{} |> Map.empty?) :true
  end
  test "map-update-pipeline" do
    m = %{} |> Map.put :n 1 |> Map.update :n 0 (fn v -> add v 10) |> Map.del :gone
    assert-eq (m |> Map.get :n) 11
    assert-eq (m |> Map.size) 1
    assert-eq (m |> Map.del :n |> Map.empty?) :true
    assert-eq (%{} |> Map.update :new 40 (fn v -> v + 2)) %{:new 42}
  end
  test "map-get-bang" do
    m = %{:a 1}
    assert-eq (m |> Map.get! :a) 1
    assert-eq (assert-raises (fn do m |> Map.get! :zz end)) {:error {:key-not-found :zz}}
  end
  test "map-merge-keys" do
    m = %{:a 1} |> Map.merge %{:b 2 :a 9}
    assert-eq (m |> Map.get :a) 9
    assert-eq (Map.keys m).length 2
  end
  test "map-expanded-surface" do
    m = %{:a 1 :b 2}
    assert-eq (m |> Map.empty?) :false
    assert-eq (m |> Map.put-new :a 9 |> Map.get :a) 1
    assert-eq (m |> Map.put-new :z 9 |> Map.get :z) 9
    assert-eq (m |> Map.replace :a 9 |> Map.get :a) 9
    assert-eq (m |> Map.replace :z 9) m
    assert-eq (m |> Map.replace! :a 9 |> Map.get :a) 9
    assert-eq (assert-raises (fn do m |> Map.replace! :z 9 end)) {:error {:key-not-found :z}}
    assert-eq (m |> Map.pop :a) {1 %{:b 2}}
    assert-eq (m |> Map.pop-or :z :missing) {:missing m}
    assert-eq (m |> Map.take '(:b :z)) %{:b 2}
    assert-eq (m |> Map.drop '(:a)) %{:b 2}
    assert-eq (m |> Map.filter (fn _k v -> gt? v 1)) %{:b 2}
    assert-eq (m |> Map.filter (fn _k _v -> :false)) %{}
    assert-eq (m |> Map.reject (fn k _v -> eq? k :a)) %{:b 2}
    assert-eq (m |> Map.map-values (fn _k v -> add v 10)) %{:a 11 :b 12}
    assert-eq (m |> Map.map-keys (fn _k v -> cond (eq? v 1) :odd :even)) %{:odd 1 :even 2}
    assert-eq (Map.from-list (Map.to-list m)) m
    assert-eq (Map.equal? m %{:b 2 :a 1}) :true
    assert-eq (Map.from-list '({:x 1} {:x 2} {:y 3})) %{:x 2 :y 3}
    assert-eq (Map.merge-with %{:a 1} %{:a 2 :b 3} (fn _k x y -> add x y)) %{:a 3 :b 3}
  end
end

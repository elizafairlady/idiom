use std/test
import std/string as Str
activate Test
import std/map as Map
use std/enum

suite do
  test "empty-values-are-distinct" do
    assert-eq (eq? '() :nil) :false
    assert-eq (eq? [] :nil) :false
    assert-eq (eq? '() []) :false
    assert-eq (eq? {} :nil) :false
    assert-eq (eq? %{} :nil) :false
    assert-eq (eq? '() (list)) :true
    assert-eq (eq? [] []) :true
    assert-eq (eq? {} {}) :true
    assert-eq (eq? %{} %{}) :true
  end
  test "exactly-nil-and-false-are-falsy" do
    assert-eq (cond :nil :t :f) :f
    assert-eq (cond :false :t :f) :f
    assert-eq (cond '() :t :f) :t
    assert-eq (cond [] :t :f) :t
    assert-eq (cond {} :t :f) :t
    assert-eq (cond %{} :t :f) :t
  end
  test "absence-is-nil-empty-is-a-value" do
    m = %{:a 1}
    missing = Map.get m :missing
    empty = '(1 2 3).filter (fn _x -> :false)
    assert-eq missing :nil
    assert-eq empty '()
    assert-eq (eq? missing empty) :false
    assert-eq ('(1 2).nth 9) :nil
    assert-eq ('(1 2).find (fn _x -> :false)) :nil
  end
  test "to-list-bridges-vector-and-list" do
    assert-eq (eq? [] '()) :false
    assert-eq [].to-list '()
    assert-eq [1 2].to-list '(1 2)
    assert-eq '(1 2).to-list '(1 2)
    match (assert-raises (fn do (:nil).to-list end)) do
      {:error {:runtime msg}} -> assert (Str.contains? msg "does not implement trait 'Enum#")
    end
  end
  test "renderings-round-trip" do
    assert-inspect [1 2] "[1 2]"
    assert-inspect [] "[]"
    assert-inspect '(1 2) "(1 2)"
    assert-inspect '() "()"
    assert-inspect {} "{}"
    assert-inspect %{} "%{}"
    assert-inspect (list 1 (list 2 3)) "(1 (2 3))"
    assert-inspect [1 [2 3]] "[1 [2 3]]"
  end
  test "quote-is-syntax-faithful" do
    assert-eq '[1 2] [1 2]
    assert-eq '[1 2] [1 2]
    assert-eq '(1 2) (list 1 2)
    assert-eq '() (list)
    assert-eq (eq? '[1 2] '(1 2)) :false
  end
  test "list-recursion-terminates-on-empty-list" do
    assert-eq (rest (list 1)) '()
    assert-eq (cons 1 '()) '(1)
    assert-eq (append '(1) '(2)) '(1 2)
    assert-eq (append '() '(9)) '(9)
    assert-inspect (assert-raises (fn -> first '())) "{:error {:type-error :first ()}}"
    assert-inspect (assert-raises (fn -> rest '())) "{:error {:type-error :rest ()}}"
  end
  test "pattern-matrix-distinguishes-empties" do
    f = fn do
      :nil -> :nil-case
      '() -> :empty-list-case
      [] -> :empty-vector-case
      {} -> :empty-tuple-case
      %{} -> :dict-case
    end
    assert-eq (f :nil) :nil-case
    assert-eq (f '()) :empty-list-case
    assert-eq (f []) :empty-vector-case
    assert-eq (f {}) :empty-tuple-case
    assert-eq (f %{}) :dict-case
    assert-eq (f (list)) :empty-list-case
    assert-eq (f []) :empty-vector-case
  end
  test "list-pattern-family" do
    g = fn do
      '() -> :empty
      (list a) -> {:one a}
      (list a . rest) -> {:cons a rest}
    end
    assert-eq (g '()) :empty
    assert-eq (g '(1)) {:one 1}
    assert-eq (g '(1 2 3)) {:cons 1 '(2 3)}
    (list) = list
    (list x y) = list 4 5
    assert-eq (add x y) 9
  end
  test "bracket-pattern-family-matches-vectors" do
    h = fn do
      [] -> :empty
      [a] -> {:one a}
      [a . rest] -> {:more a rest}
    end
    assert-eq (h []) :empty
    assert-eq (h [1]) {:one 1}
    assert-eq (h [1 2 3]) {:more 1 [2 3]}
    no-list = fn do
      [a b] -> {a b}
      _ -> :not-a-vector
    end
    assert-eq (no-list '(1 2)) :not-a-vector
  end
  test "enum-is-polymorphic-and-returns-lists" do
    double = fn x -> mul x 2
    assert-eq ('(1 2).map double) '(2 4)
    assert-eq ([1 2].map double) '(2 4)
    assert-eq ({1 2}.map double) '(2 4)
    assert-eq (%{:a 1}.map (fn kv -> kv)) '({:a 1})
    assert-eq ([1 2 3 4].filter (fn x -> gt? x 2)) '(3 4)
    assert-eq ([].filter (fn _x -> :true)) '()
    assert-eq ([1 2 3].reduce 0 &add) 6
    assert-eq [1 2 3].length 3
    assert-eq {1 2 3}.sum 6
    assert-eq [1 2 3].reverse '(3 2 1)
    assert-eq ([1 2].member? 2) :true
    assert-eq ([7 8].nth 1) 8
    assert-eq ([1 2 3].take 2) '(1 2)
    assert-eq ([1 2 3].drop 2) '(3)
    assert-eq ([1].concat '(2)) '(1 2)
    assert-eq ([1 2].zip '(:a :b)) '({1 :a} {2 :b})
    assert-eq [3 1 2].sort '(1 2 3)
    assert-eq %{:b 2}.to-list.map (fn kv -> kv) '({:b 2})
  end
  test "empties-survive-quote-constants" do
    constants = list '() (list 1 '()) 2
    assert-inspect constants "(() (1 ()) 2)"
    assert-eq constants (cons '() (cons (cons 1 (cons '() '())) (cons 2 '())))
    vec-constant = '[1 2]
    assert-inspect vec-constant "[1 2]"
    assert-eq (first constants) '()
  end
end

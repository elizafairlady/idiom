use std/test
use std/string
use app/ish
use std/term
activate Test

defn fresh -> initial-state "> "

defn with-buffer state text cursor -> dict-put (dict-put state :buffer text) :cursor cursor

defn feed do
  state '() -> state
  state (list k . rest) -> match (step state k) do
    {_ st} -> feed st rest
  end
end

defn esc-seq text -> "#{byte-str 27}[${text}"

suite do
  test "insert-and-motion" do
    s = feed fresh (list {:char "a"} {:char "b"} {:char "c"} :left :left {:char "X"})
    assert-eq {(dict-get s :buffer :nil) (dict-get s :cursor :nil)} {"aXbc" 2}
  end
  test "home-end-line-bound" do
    s = feed (with-buffer fresh "one\ntwo" 5) (list :c-a)
    assert-eq (dict-get s :cursor :nil) 4
    s2 = feed s (list :c-e)
    assert-eq (dict-get s2 :cursor :nil) 7
  end
  test "word-motion" do
    s = feed (with-buffer fresh "echo hi there" 13) (list :m-b :m-b)
    assert-eq (dict-get s :cursor :nil) 5
    s2 = feed s (list :m-f)
    assert-eq (dict-get s2 :cursor :nil) 7
  end
  test "backspace-delete" do
    s = feed (with-buffer fresh "abc" 2) (list :backspace :delete)
    assert-eq (dict-get s :buffer :nil) "a"
  end
  test "kill-to-line-end-and-yank" do
    s = feed (with-buffer fresh "hello world" 5) (list :c-k)
    assert-eq {(dict-get s :buffer :nil) (dict-get s :kill :nil)} {"hello" " world"}
    s2 = feed s (list :c-y :c-y)
    assert-eq (dict-get s2 :buffer :nil) "hello world world"
  end
  test "kill-to-line-start" do
    s = feed (with-buffer fresh "hello world" 6) (list :c-u)
    assert-eq {(dict-get s :buffer :nil) (dict-get s :kill :nil) (dict-get s :cursor :nil)} {"world" "hello " 0}
  end
  test "kill-word-back" do
    s = feed (with-buffer fresh "git commit  " 12) (list :c-w)
    assert-eq {(dict-get s :buffer :nil) (dict-get s :kill :nil)} {"git " "commit  "}
  end
  test "kill-newline-at-line-end" do
    s = feed (with-buffer fresh "ab\ncd" 2) (list :c-k)
    assert-eq (dict-get s :buffer :nil) "abcd"
  end
  test "ctrl-d-deletes-or-eof" do
    s = feed (with-buffer fresh "ab" 0) (list :c-d)
    assert-eq (dict-get s :buffer :nil) "b"
    {tag _} = step fresh :c-d
    assert-eq tag :eof
  end
  test "enter-submits-ctrl-c-cancels-tab-noop" do
    {t1 _} = step (with-buffer fresh "x" 1) :enter
    {t2 _} = step (with-buffer fresh "x" 1) :c-c
    {t3 s3} = step (with-buffer fresh "x" 1) :tab
    assert-eq {t1 t2 t3 (dict-get s3 :buffer :nil)} {:submit :cancel :render "x"}
  end
  test "history-walk-preserves-pending-line" do
    s = push-history (push-history fresh "first") "second"
    s1 = feed (with-buffer s "draft" 5) (list :up)
    assert-eq (dict-get s1 :buffer :nil) "second"
    s2 = feed s1 (list :up :down :down)
    assert-eq (dict-get s2 :buffer :nil) "draft"
  end
  test "history-dedup-and-empty-skip" do
    s = push-history (push-history (push-history fresh "a") "a") ""
    s1 = feed s (list :up :up)
    assert-eq {(dict-get s1 :buffer :nil) (dict-get s1 :hist-pos :nil)} {"a" 0}
  end
  test "reverse-search-incremental" do
    s = push-history (push-history (push-history fresh "echo alpha") "ls beta") "pwd"
    s1 = feed s (list :c-r {:char "a"})
    assert-eq {(dict-get s1 :mode :nil) (dict-get s1 :buffer :nil)} {:search "ls beta"}
    s2 = feed s1 (list :c-r)
    assert-eq (dict-get s2 :buffer :nil) "echo alpha"
    {tag s3} = step s2 :enter
    assert-eq {tag (dict-get s3 :mode :nil) (dict-get s3 :buffer :nil)} {:submit :edit "echo alpha"}
  end
  test "reverse-search-cancel-restores" do
    s = push-history fresh "history-line"
    s1 = feed (with-buffer s "typed" 5) (list :c-r {:char "h"} :c-c)
    assert-eq {(dict-get s1 :mode :nil) (dict-get s1 :buffer :nil) (dict-get s1 :cursor :nil)} {:edit "typed" 5}
  end
  test "multiline-continuation-edits-as-one-unit" do
    {tag s1} = step (with-buffer fresh "do" 2) :enter
    assert-eq tag :submit
    s2 = continue s1
    assert-eq {(dict-get s2 :buffer :nil) (dict-get s2 :cursor :nil)} {"do\n" 3}
    s3 = feed s2 (list {:char "x"} :c-a)
    assert-eq {(dict-get s3 :buffer :nil) (dict-get s3 :cursor :nil)} {"do\nx" 3}
  end
  test "redraw-simple-line" do
    {st out} = redraw (with-buffer fresh "ab" 2)
    assert-eq out "\r#{esc-seq "J"}> ab\r#{esc-seq "4C"}"
    assert-eq (dict-get st :row :nil) 0
  end
  test "redraw-multiline-continuation-prompt" do
    {st out} = redraw (with-buffer fresh "ab\ncd" 1)
    assert-eq out "\r#{esc-seq "J"}> ab\r\n...> cd#{esc-seq "1A"}\r#{esc-seq "3C"}"
    assert-eq {(dict-get st :row :nil) (dict-get st :below :nil)} {0 1}
  end
  test "redraw-moves-up-from-previous-row" do
    s = dict-put (with-buffer fresh "ab" 2) :row 2
    {_ out} = redraw s
    assert (starts-with? out "\r#{esc-seq "2A"}#{esc-seq "J"}")
  end
  test "redraw-wraps-by-byte-columns" do
    s = dict-put (with-buffer fresh "abcdef" 6) :cols 4
    {st _} = redraw s
    assert-eq (dict-get st :row :nil) 1
  end
  test "redraw-strips-csi-from-prompt-width" do
    colored = "#{byte-str 27}[1;32m> #{byte-str 27}[0m"
    s = with-buffer (initial-state colored) "ab" 2
    {st out} = redraw s
    assert-eq (dict-get st :row :nil) 0
    assert (contains? out (esc-seq "4C"))
  end
  test "keymap-is-a-dict-rebind-tab" do
    s = bind-key fresh :tab (fn st -> step st {:char " "})
    {tag s1} = step s :tab
    assert-eq {tag (dict-get s1 :buffer :nil)} {:render " "}
  end
  test "keymap-rebind-printable-key" do
    s = bind-key fresh {:char "q"} (fn st -> {:submit st})
    {tag _} = step s {:char "q"}
    assert-eq tag :submit
    {t2 s2} = step fresh {:char "q"}
    assert-eq {t2 (dict-get s2 :buffer :nil)} {:render "q"}
  end
  test "decode-byte-table" do
    assert-eq (decode-byte 1) :c-a
    assert-eq (decode-byte 13) :enter
    assert-eq (decode-byte 127) :backspace
    assert-eq (decode-byte 18) :c-r
    assert-eq (decode-byte 65) {:char "A"}
    assert-eq (decode-byte 7) :c-g
    assert-eq (decode-byte 15) :c-o
    assert-eq (decode-byte 22) :c-v
    assert-eq (decode-byte 24) :c-x
  end
  test "csi-key-table" do
    assert-eq (csi-key 68 "") :left
    assert-eq (csi-key 72 "") :home
    assert-eq (csi-key 126 "3") :delete
    assert-eq (csi-key 126 "5") :page-up
    assert-eq (csi-key 126 "9") :unknown
  end
  test "reset-clears-line-state-keeps-history" do
    s = push-history fresh "kept"
    s1 = reset (feed (with-buffer s "junk" 4) (list :up))
    assert-eq {(dict-get s1 :buffer :nil) (dict-get s1 :cursor :nil) (dict-get s1 :hist-pos :nil)} {"" 0 (sub 0 1)}
    s2 = feed s1 (list :up)
    assert-eq (dict-get s2 :buffer :nil) "kept"
  end
  test "rune-motion-crosses-whole-codepoint" do
    zhong = from-runes (list 20013)
    s = with-buffer fresh "${zhong}x" 4
    s1 = feed s (list :left)
    assert-eq (dict-get s1 :cursor :nil) 3
    s2 = feed s1 (list :left)
    assert-eq (dict-get s2 :cursor :nil) 0
  end
  test "rune-backspace-deletes-whole-codepoint" do
    zhong = from-runes (list 20013)
    s = feed (with-buffer fresh "a${zhong}" 4) (list :backspace)
    assert-eq (dict-get s :buffer :nil) "a"
  end
  test "redraw-wraps-by-display-width-not-bytes" do
    zhong = from-runes (list 20013)
    s = dict-put (dict-put (with-buffer fresh "${zhong}${zhong}" 6) :prompt "") :cols 5
    {st _} = redraw s
    assert-eq {(dict-get st :row :nil) (dict-get st :below :nil)} {0 0}
  end
  test "redraw-cursor-forward-uses-display-columns" do
    zhong = from-runes (list 20013)
    {_ out} = redraw (with-buffer fresh "${zhong}${zhong}" 6)
    assert (contains? out (esc-seq "6C"))
  end
end

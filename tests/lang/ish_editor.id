use std/test
use std/string
use std/ish
implement std/test

defn fresh tag -> initial-state "> "

defn with-buffer state text cursor -> dict-put (dict-put state :buffer text) :cursor cursor

defn feed do
  state '() -> state
  state (list k . rest) -> match (step state k) do
    {_ st} -> feed st rest
  end
end

defn esc-seq text -> str (byte-str 27) "[" text

suite do
  test "insert-and-motion" do
    s = feed (fresh :go) (list (tuple :char "a") (tuple :char "b") (tuple :char "c") :left :left (tuple :char "X"))
    assert-eq (tuple (dict-get s :buffer :nil) (dict-get s :cursor :nil)) (tuple "aXbc" 2)
  end
  test "home-end-line-bound" do
    s = feed (with-buffer (fresh :go) "one\ntwo" 5) (list :c-a)
    assert-eq (dict-get s :cursor :nil) 4
    s2 = feed s (list :c-e)
    assert-eq (dict-get s2 :cursor :nil) 7
  end
  test "word-motion" do
    s = feed (with-buffer (fresh :go) "echo hi there" 13) (list :m-b :m-b)
    assert-eq (dict-get s :cursor :nil) 5
    s2 = feed s (list :m-f)
    assert-eq (dict-get s2 :cursor :nil) 7
  end
  test "backspace-delete" do
    s = feed (with-buffer (fresh :go) "abc" 2) (list :backspace :delete)
    assert-eq (dict-get s :buffer :nil) "a"
  end
  test "kill-to-line-end-and-yank" do
    s = feed (with-buffer (fresh :go) "hello world" 5) (list :c-k)
    assert-eq (tuple (dict-get s :buffer :nil) (dict-get s :kill :nil)) (tuple "hello" " world")
    s2 = feed s (list :c-y :c-y)
    assert-eq (dict-get s2 :buffer :nil) "hello world world"
  end
  test "kill-to-line-start" do
    s = feed (with-buffer (fresh :go) "hello world" 6) (list :c-u)
    assert-eq (tuple (dict-get s :buffer :nil) (dict-get s :kill :nil) (dict-get s :cursor :nil)) (tuple "world" "hello " 0)
  end
  test "kill-word-back" do
    s = feed (with-buffer (fresh :go) "git commit  " 12) (list :c-w)
    assert-eq (tuple (dict-get s :buffer :nil) (dict-get s :kill :nil)) (tuple "git " "commit  ")
  end
  test "kill-newline-at-line-end" do
    s = feed (with-buffer (fresh :go) "ab\ncd" 2) (list :c-k)
    assert-eq (dict-get s :buffer :nil) "abcd"
  end
  test "ctrl-d-deletes-or-eof" do
    s = feed (with-buffer (fresh :go) "ab" 0) (list :c-d)
    assert-eq (dict-get s :buffer :nil) "b"
    {tag _} = step (fresh :go) :c-d
    assert-eq tag :eof
  end
  test "enter-submits-ctrl-c-cancels-tab-noop" do
    {t1 _} = step (with-buffer (fresh :go) "x" 1) :enter
    {t2 _} = step (with-buffer (fresh :go) "x" 1) :c-c
    {t3 s3} = step (with-buffer (fresh :go) "x" 1) :tab
    assert-eq (tuple t1 t2 t3 (dict-get s3 :buffer :nil)) (tuple :submit :cancel :render "x")
  end
  test "history-walk-preserves-pending-line" do
    s = push-history (push-history (fresh :go) "first") "second"
    s1 = feed (with-buffer s "draft" 5) (list :up)
    assert-eq (dict-get s1 :buffer :nil) "second"
    s2 = feed s1 (list :up :down :down)
    assert-eq (dict-get s2 :buffer :nil) "draft"
  end
  test "history-dedup-and-empty-skip" do
    s = push-history (push-history (push-history (fresh :go) "a") "a") ""
    s1 = feed s (list :up :up)
    assert-eq (tuple (dict-get s1 :buffer :nil) (dict-get s1 :hist-pos :nil)) (tuple "a" 0)
  end
  test "reverse-search-incremental" do
    s = push-history (push-history (push-history (fresh :go) "echo alpha") "ls beta") "pwd"
    s1 = feed s (list :c-r (tuple :char "a"))
    assert-eq (tuple (dict-get s1 :mode :nil) (dict-get s1 :buffer :nil)) (tuple :search "ls beta")
    s2 = feed s1 (list :c-r)
    assert-eq (dict-get s2 :buffer :nil) "echo alpha"
    {tag s3} = step s2 :enter
    assert-eq (tuple tag (dict-get s3 :mode :nil) (dict-get s3 :buffer :nil)) (tuple :submit :edit "echo alpha")
  end
  test "reverse-search-cancel-restores" do
    s = push-history (fresh :go) "history-line"
    s1 = feed (with-buffer s "typed" 5) (list :c-r (tuple :char "h") :c-c)
    assert-eq (tuple (dict-get s1 :mode :nil) (dict-get s1 :buffer :nil) (dict-get s1 :cursor :nil)) (tuple :edit "typed" 5)
  end
  test "multiline-continuation-edits-as-one-unit" do
    {tag s1} = step (with-buffer (fresh :go) "do" 2) :enter
    assert-eq tag :submit
    s2 = continue s1
    assert-eq (tuple (dict-get s2 :buffer :nil) (dict-get s2 :cursor :nil)) (tuple "do\n" 3)
    s3 = feed s2 (list (tuple :char "x") :c-a)
    assert-eq (tuple (dict-get s3 :buffer :nil) (dict-get s3 :cursor :nil)) (tuple "do\nx" 3)
  end
  test "redraw-simple-line" do
    {st out} = redraw (with-buffer (fresh :go) "ab" 2)
    assert-eq out (str "\r" (esc-seq "J") "> ab" "\r" (esc-seq "4C"))
    assert-eq (dict-get st :row :nil) 0
  end
  test "redraw-multiline-continuation-prompt" do
    {st out} = redraw (with-buffer (fresh :go) "ab\ncd" 1)
    assert-eq out (str "\r" (esc-seq "J") "> ab" "\r\n" "...> cd" (esc-seq "1A") "\r" (esc-seq "3C"))
    assert-eq (tuple (dict-get st :row :nil) (dict-get st :below :nil)) (tuple 0 1)
  end
  test "redraw-moves-up-from-previous-row" do
    s = dict-put (with-buffer (fresh :go) "ab" 2) :row 2
    {_ out} = redraw s
    assert (starts-with? out (str "\r" (esc-seq "2A") (esc-seq "J")))
  end
  test "redraw-wraps-by-byte-columns" do
    s = dict-put (with-buffer (fresh :go) "abcdef" 6) :cols 4
    {st _} = redraw s
    assert-eq (dict-get st :row :nil) 1
  end
  test "redraw-strips-csi-from-prompt-width" do
    colored = str (byte-str 27) "[1;32m" "> " (byte-str 27) "[0m"
    s = with-buffer (initial-state colored) "ab" 2
    {st out} = redraw s
    assert-eq (dict-get st :row :nil) 0
    assert (contains? out (esc-seq "4C"))
  end
  test "keymap-is-a-dict-rebind-tab" do
    s = bind-key (fresh :go) :tab (fn st -> step st (tuple :char " "))
    {tag s1} = step s :tab
    assert-eq (tuple tag (dict-get s1 :buffer :nil)) (tuple :render " ")
  end
  test "keymap-rebind-printable-key" do
    s = bind-key (fresh :go) (tuple :char "q") (fn st -> tuple :submit st)
    {tag _} = step s (tuple :char "q")
    assert-eq tag :submit
    {t2 s2} = step (fresh :go) (tuple :char "q")
    assert-eq (tuple t2 (dict-get s2 :buffer :nil)) (tuple :render "q")
  end
  test "decode-byte-table" do
    assert-eq (decode-byte 1) :c-a
    assert-eq (decode-byte 13) :enter
    assert-eq (decode-byte 127) :backspace
    assert-eq (decode-byte 18) :c-r
    assert-eq (decode-byte 65) (tuple :char "A")
    assert-eq (decode-byte 7) :unknown
  end
  test "csi-key-table" do
    assert-eq (csi-key 68 "") :left
    assert-eq (csi-key 72 "") :home
    assert-eq (csi-key 126 "3") :delete
    assert-eq (csi-key 126 "9") :unknown
  end
  test "reset-clears-line-state-keeps-history" do
    s = push-history (fresh :go) "kept"
    s1 = reset (feed (with-buffer s "junk" 4) (list :up))
    assert-eq (tuple (dict-get s1 :buffer :nil) (dict-get s1 :cursor :nil) (dict-get s1 :hist-pos :nil)) (tuple "" 0 (sub 0 1))
    s2 = feed s1 (list :up)
    assert-eq (dict-get s2 :buffer :nil) "kept"
  end
end

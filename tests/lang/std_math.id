use std/test
activate std/test
import std/math as Math

defn close? a b -> (Math.abs (a - b)) < 0.000001

suite do
  test "stdlib-math-constants-and-classifiers" do
    assert (close? (Math.pi) 3.141592653589793)
    assert (close? (Math.tau) 6.283185307179586)
    assert (close? (Math.e) 2.718281828459045)
    assert-eq (Math.nan) :nan
    assert-eq (Math.inf) :inf
    assert-eq ((Math.nan) |> Math.nan?) :true
    assert-eq ((Math.inf) |> Math.nan?) :false
    assert-eq ((Math.inf) |> Math.infinite?) :true
    assert-eq ((Math.nan) |> Math.infinite?) :false
    assert-eq (42 |> Math.finite?) :true
    assert-eq ((Math.inf) |> Math.finite?) :false
    assert-eq ((Math.nan) |> Math.finite?) :false
    assert-eq (2 |> Math.asin) :nan
    assert-eq ((2 |> Math.asin) |> Math.nan?) :true
    assert-eq (0.0 |> Math.log) :inf
    assert-eq ((0.0 |> Math.log) |> Math.infinite?) :true
    assert-eq (Math.pow (neg 1.0) 0.5) :nan
  end
  test "stdlib-math-libm-surface" do
    assert-eq (Math.abs -5) 5
    assert-eq (Math.floor 2.7) 2.0
    assert-eq (Math.ceil 2.1) 3.0
    assert-eq (Math.truncate (neg 2.9)) -2.0
    assert-eq (Math.round 2.5) 3.0
    assert-eq (Math.sqrt 9) 3.0
    assert-eq (Math.pow 2 10) 1024
    assert (close? (Math.sin 0) 0.0)
    assert (close? (Math.cos 0) 1.0)
    assert (close? (Math.tan 0) 0.0)
    assert (close? (Math.asin 1) ((Math.pi) / 2.0))
    assert (close? (Math.acos 1) 0.0)
    assert (close? (Math.atan 1) ((Math.pi) / 4.0))
    assert (close? (Math.atan2 1 1) ((Math.pi) / 4.0))
    assert (close? (Math.exp 1) (Math.e))
    assert (close? (Math.log (Math.e)) 1.0)
    assert (close? (Math.log2 8) 3.0)
    assert (close? (Math.log10 1000) 3.0)
    assert (close? (Math.hypot 3 4) 5.0)
  end
  test "stdlib-math-division-and-conversion-surface" do
    assert-eq (Math.quot -7 2) -3
    assert-eq (Math.rem -7 2) -1
    assert-eq (Math.quot-rem -7 2) {-3 -1}
    assert-eq (Math.floor-div -7 2) -4
    assert-eq (Math.floor-mod -7 2) 1
    assert-eq (Math.divmod -7 2) {-4 1}
    assert-eq (Math.divmod -7.5 2) {-4.0 0.5}
    assert-eq (Math.to-int 2.9) 2
    assert-eq (Math.to-int (neg 2.9)) -2
    assert-eq (Math.to-float 2) 2.0
    assert-eq (assert-raises (fn do Math.divmod 1 0 end)) {:error {:div-by-zero :divmod}}
    assert-eq (assert-raises (fn do Math.to-int (Math.inf) end)) {:error {:type-error :to-int :inf}}
    assert-eq (assert-raises (fn do Math.to-float :x end)) {:error {:type-error :to-float :x}}
  end
  test "stdlib-math-bit-surface" do
    assert-eq (Math.bit-and 6 3) 2
    assert-eq (Math.bit-or 6 3) 7
    assert-eq (Math.bit-xor 6 3) 5
    assert-eq (Math.bit-not 0) -1
    assert-eq (Math.shift-left 3 4) 48
    assert-eq (Math.shift-right 32 3) 4
    assert-eq (Math.shift-right -8 1) -4
    assert-eq (Math.bit-count 0) 0
    assert-eq (Math.bit-count 11) 3
    assert-eq (Math.bit-length 0) 0
    assert-eq (Math.bit-length 8) 4
    assert-eq (assert-raises (fn do Math.bit-count -1 end)) {:error {:type-error :bit-count -1}}
    assert-eq (assert-raises (fn do Math.shift-left 1 -1 end)) {:error {:type-error :shift-left -1}}
  end
  test "stdlib-math-predicates-and-bounds" do
    assert-eq (Math.zero? 0) :true
    assert-eq (Math.zero? 1) :false
    assert-eq (Math.positive? 2) :true
    assert-eq (Math.positive? 0) :false
    assert-eq (Math.negative? -2) :true
    assert-eq (Math.negative? 0) :false
    assert-eq (Math.nonnegative? 0) :true
    assert-eq (Math.nonpositive? 0) :true
    assert-eq (Math.even? -4) :true
    assert-eq (Math.odd? -3) :true
    assert-eq (Math.min 2 9) 2
    assert-eq (Math.max 2 9) 9
    assert-eq (Math.clamp -4 0 10) 0
    assert-eq (Math.clamp 14 0 10) 10
    assert-eq (Math.clamp 4 0 10) 4
    assert-eq (Math.between? 0 0 10) :true
    assert-eq (Math.between? 11 0 10) :false
    assert-eq {(Math.sign -9) (Math.sign 0) (Math.sign 9)} {(neg 1) 0 1}
  end
  test "stdlib-math-integer-functions" do
    assert-eq (Math.gcd -54 24) 6
    assert-eq (Math.gcd 0 9) 9
    assert-eq (Math.lcm 6 8) 24
    assert-eq (Math.lcm 0 8) 0
    assert-eq (Math.square -7) 49
    assert-eq (Math.cube -3) (neg 27)
    assert-eq (Math.pow-int 3 4) 81
    assert-eq (Math.pow-int 9 0) 1
    assert-eq (Math.factorial 6) 720
    assert-eq (Math.factorial 0) 1
    assert-eq (assert-raises (fn do Math.pow-int 2 (neg 1) end)) {:error {:negative-exponent (neg 1)}}
    assert-eq (assert-raises (fn do Math.factorial (neg 1) end)) {:error {:negative-factorial (neg 1)}}
  end
  test "abs" do
    assert-eq (abs 5) 5
    assert-eq (abs -5) 5
    assert-eq (abs 0) 0
    assert-eq (abs 2.5) 2.5
    assert-eq (abs (neg 2.5)) 2.5
    assert-eq (-5 |> abs) 5
    int-min = 0 - 9223372036854775807 - 1
    assert-eq (assert-raises (fn do abs int-min end)) {:error {:overflow :abs}}
    assert-eq (assert-raises (fn do abs :x end)) {:error {:type-error :abs :x}}
  end
  test "floor-and-round-keep-their-kind" do
    assert-eq (floor 2.7) 2.0
    assert-eq (floor (neg 2.7)) -3.0
    assert-eq (floor 5) 5
    assert-eq (floor -5) -5
    assert-eq (round 2.4) 2.0
    assert-eq (round 2.5) 3.0
    assert-eq (round (neg 2.5)) -3.0
    assert-eq (round 7) 7
    assert-eq (2.7 |> floor) 2.0
    assert-eq (assert-raises (fn do floor "2.7" end)) {:error {:type-error :floor "2.7"}}
    assert-eq (assert-raises (fn do round :nil end)) {:error {:type-error :round :nil}}
  end
  test "sqrt-always-float" do
    assert-eq (sqrt 4) 2.0
    assert-eq (sqrt 2.25) 1.5
    assert-eq (sqrt 0) 0.0
    assert-eq (9 |> sqrt) 3.0
    assert-eq (assert-raises (fn do sqrt -4 end)) {:error {:type-error :sqrt -4}}
    assert-eq (assert-raises (fn do sqrt (neg 0.5) end)) {:error {:type-error :sqrt -0.5}}
    assert-eq (assert-raises (fn do sqrt "4" end)) {:error {:type-error :sqrt "4"}}
  end
  test "floor-div-sign-matrix" do
    assert-eq (7 // 2) 3
    assert-eq (-7 // 2) -4
    assert-eq (7 // -2) -4
    assert-eq (-7 // -2) 3
    assert-eq (6 // 3) 2
    assert-eq (-6 // 3) -2
    assert-eq (floor-div -7 2) -4
    assert-eq (7.5 // 2) 3.0
    assert-eq (-7.5 // 2) -4.0
  end
  test "floor-mod-sign-follows-divisor" do
    assert-eq (7 %% 2) 1
    assert-eq (-7 %% 2) 1
    assert-eq (7 %% -2) -1
    assert-eq (-7 %% -2) -1
    assert-eq (-6 %% 3) 0
    assert-eq (floor-mod -7 2) 1
    assert-eq (7.5 %% 2) 1.5
    assert-eq (-7.5 %% 2) 0.5
    assert-eq (-7 % 2) -1
  end
  test "floor-div-mod-traps" do
    assert-eq (assert-raises (fn do 7 // 0 end)) {:error {:div-by-zero :floor-div}}
    assert-eq (assert-raises (fn do 7 %% 0 end)) {:error {:div-by-zero :floor-mod}}
    int-min = 0 - 9223372036854775807 - 1
    assert-eq (assert-raises (fn do int-min // -1 end)) {:error {:overflow :floor-div}}
    assert-eq (assert-raises (fn do int-min %% -1 end)) {:error {:overflow :floor-mod}}
    assert-eq (assert-raises (fn do :x // 2 end)) {:error {:type-error :floor-div :x 2}}
  end
end

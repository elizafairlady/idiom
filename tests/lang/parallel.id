use std/test
activate Test
use std/enum

suite do
  test "fan-out-fan-in" do
    got = do
      parent = self
      (range 0 50).map (fn i -> spawn (fn -> send parent {:res (i * i)}))
      defn gather do
        0 acc -> acc
        n acc -> receive do {:res sq} -> gather (n - 1) (acc + sq) end
      end
      gather 50 0
    end
    assert-inspect got "40425"
  end
  test "pairwise-fifo" do
    got = do
      parent = self
      spawn (fn do (range 0 20).map (fn k -> send parent {:seq k}) end)
      defn drain do
        0 acc -> acc.reverse
        n acc -> receive do {:seq k} -> drain (n - 1) (cons k acc) end
      end
      eq? (inspect (drain 20 '())) (inspect (range 0 20))
    end
    assert-inspect got ":true"
  end
  test "ping-pong-rally" do
    got = do
      parent = self
      ponger = spawn (fn do
        defn serve served -> receive do
          {:ping from k} -> do
            send from {:pong k}
            serve (served + 1)
          end
        end
        serve 0
      end)
      defn rally do
        0 -> :done
        n -> do
          send ponger {:ping parent n}
          receive do {:pong k} -> rally (n - 1) end
        end
      end
      rally 100
    end
    assert-inspect got ":done"
  end
  test "parallel-gc-load" do
    got = do
      parent = self
      defn build do
        0 acc -> acc
        n acc -> build (n - 1) (cons n acc)
      end
      (range 0 8).map (fn _i -> spawn (fn -> send parent {:sum (build 5000 '()).sum}))
      defn gather do
        0 acc -> acc
        n acc -> receive do {:sum s} -> gather (n - 1) (acc + s) end
      end
      gather 8 0
    end
    assert-inspect got "100020000"
  end
  test "rescued-value-survives-gc" do
    got = do
      defn build do
        0 acc -> acc
        n acc -> build (n - 1) (cons n acc)
      end
      defn churn do
        0 -> :ok
        n -> do
          build 2000 '()
          churn (n - 1)
        end
      end
      spawn (fn -> churn 5000)
      defn hammer do
        0 -> :done
        n -> do
          r = try do raise {:v n (build 200 '())}; rescue e -> e end
          match r do {:v k '(h . _)} -> cond (and (eq? k n) (eq? h 1)) (hammer (n - 1)) :corrupt end
        end
      end
      hammer 5000
    end
    assert-inspect got ":done"
  end
  test "receive-after-fires-under-load" do
    got = do
      (range 0 8).map (fn _i -> spawn (fn do
        defn spin k -> spin (k + 1)
        spin 0
      end))
      receive do
        {:never x} -> x
        after 50 -> :woke
      end
    end
    assert-inspect got ":woke"
  end
  test "kill-running-actor" do
    got = do
      victim = spawn (fn do
        defn spin n -> spin (n + 1)
        spin 0
      end)
      monitor victim
      spawn (fn do
        link victim
        raise :boom
      end)
      receive do
        {:down _ref _pid reason} -> reason
        after 5000 -> :timeout
      end
    end
    assert-inspect got ":boom"
  end
  test "kill-spinning-actors" do
    got = do
      victims = (range 0 8).map (fn _i -> spawn (fn do
        defn spin n -> spin (n + 1)
        spin 0
      end))
      victims.map (fn v -> monitor v)
      victims.map (fn v -> exit v :kill)
      defn gather do
        0 -> :done
        n -> receive do {:down _ _ :killed} -> gather (n - 1) end
      end
      gather 8
    end
    assert-inspect got ":done"
  end
  test "kill-chain-through-links" do
    got = do
      parent = self
      defn chain do
        0 -> do
          send parent {:node (self)}
          receive do {:never x} -> x end
        end
        k -> do
          c = spawn (fn -> chain (k - 1))
          link c
          send parent {:node (self)}
          receive do {:never x} -> x end
        end
      end
      root = spawn (fn -> chain 5)
      defn collect do
        0 acc -> acc
        n acc -> receive do {:node p} -> collect (n - 1) (cons p acc) end
      end
      pids = collect 6 '()
      pids.map (fn p -> monitor p)
      exit root :kill
      defn gather do
        0 -> :done
        n -> receive do {:down _ _ :killed} -> gather (n - 1) end
      end
      gather 6
    end
    assert-inspect got ":done"
  end
  test "kill-storm-on-allocating-actors" do
    got = do
      defn build do
        0 acc -> acc
        n acc -> build (n - 1) (cons n acc)
      end
      victims = (range 0 8).map (fn _i -> spawn (fn do
        defn churn k do
          build 500 :nil
          churn (k + 1)
        end
        churn 0
      end))
      victims.map (fn v -> monitor v)
      victims.map (fn v -> exit v :kill)
      defn gather do
        0 -> :done
        n -> receive do {:down _ _ :killed} -> gather (n - 1) end
      end
      gather 8
    end
    assert-inspect got ":done"
  end
  test "trap-exit-toggle-under-exit" do
    got = do
      victim = spawn (fn do
        defn flip n do
          trap-exit :true
          trap-exit :false
          flip (n + 1)
        end
        flip 0
      end)
      spawn (fn do
        link victim
        raise :boom
      end)
      receive do
        {:never x} -> x
        after 200 -> :ok
      end
    end
    assert-inspect got ":ok"
  end
end

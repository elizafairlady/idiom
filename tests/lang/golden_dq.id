use std/test
activate std/test

suite do
  test "dq-atom" do
    got = do
      ':ok
    end
    assert-inspect got ":ok"
  end
  test "dq-list" do
    got = do
      '(a b c)
    end
    assert-inspect got "(a b c)"
  end
  test "dq-nested" do
    got = do
      '(a (b c))
    end
    assert-inspect got "(a (b c))"
  end
  test "dq-word" do
    got = do
      'foo
    end
    assert-inspect got "foo"
  end
end

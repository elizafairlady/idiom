use std/test
activate std/test
use std/enum

suite do
  test "enum-map" do
    got = [1 2 3 4].map (fn x -> mul x x)
    assert-inspect got "(1 4 9 16)"
  end
  test "enum-filter" do
    got = [1 2 3 4].filter (fn x -> gt? x 2)
    assert-inspect got "(3 4)"
  end
  test "enum-compose" do
    got = ([1 2 3].filter (fn x -> gt? x 1)).map (fn x -> add x 1)
    assert-inspect got "(3 4)"
  end
  test "enum-reduce" do
    assert-eq ([1 2 3 4].reduce 0 &add) 10
    assert-eq ([1 2 3 4].fold 0 &add) 10
  end
  test "enum-reduce-poly" do
    assert-eq ({10 20 30}.reduce 0 &add) 60
  end
  test "enum-reverse" do
    assert-inspect [1 2 3].reverse "(3 2 1)"
  end
  test "enum-length" do
    assert-eq [9 9 9 9].length 4
  end
  test "enum-sum" do
    assert-eq [1 2 3 4 5].sum 15
  end
  test "enum-member" do
    assert-eq ([1 2 3].member? 3) :true
    assert-eq ([1 2 3].member? 7) :false
  end
  test "enum-concat" do
    assert-inspect ([1 2].concat [3 4]) "(1 2 3 4)"
  end
  test "enum-take-drop-nth" do
    assert-inspect ([7 8 9].take 2) "(7 8)"
    assert-inspect ([7 8 9].drop 1) "(8 9)"
    assert-eq ([4 5 6].nth 1) 5
    assert-eq ([4 5 6].nth 9) :nil
    assert-eq ([4 5 6].nth (neg 1)) :nil
    assert-eq ([4 5 6].nth! 2) 6
    assert-eq (assert-raises (fn do [4 5 6].nth! 9 end)) {:error {:index-out-of-range 9}}
    assert-eq (assert-raises (fn do [4 5 6].nth! (neg 1) end)) {:error {:index-out-of-range (neg 1)}}
  end
  test "enum-floats" do
    assert-eq [1.5 2.5].sum 4.0
    assert-inspect [3.5 1.5 2].sort "(1.5 2 3.5)"
    assert-eq [3 1.5].min-of 1.5
    assert-eq [1.5 3].max-of 3
  end
  test "enum-predicates" do
    assert-eq ([1 2 3].any? (fn x -> eq? x 2)) :true
    assert-eq ([1 2 3].all? (fn x -> gt? x 0)) :true
    assert-eq ([1 2 3].all? (fn x -> gt? x 1)) :false
    assert-eq ([1 2 3].find (fn x -> gt? x 1)) 2
    assert-eq ('().any? (fn _ -> :true)) :false
    assert-eq ('().all? (fn _ -> :false)) :true
  end
  test "enum-zip-range-sort" do
    assert-inspect (range 1 4) "(1 2 3)"
    assert-inspect ([1 2].zip [:a :b]) "({1 :a} {2 :b})"
    assert-inspect [3 1 2].sort "(1 2 3)"
    assert-inspect ([20 3 1].sort-by (fn a b -> a |> str |> compare (b |> str) |> eq? :lt)) "(1 20 3)"
    assert-eq [3 1 2].min-of 1
    assert-eq [3 1 2].max-of 3
  end
  test "enum-flat-map" do
    assert-inspect ([1 2].flat-map (fn x -> list x x)) "(1 1 2 2)"
  end
  test "enum-group-by" do
    g = [1 2 3 4].group-by (fn x -> mod x 2)
    assert-eq (dict-get g 0 :nil).length 2
  end
  test "enum-expanded-surface" do
    xs = [1 2 2 3 4]
    assert-eq (xs.reject (fn x -> eq? x 2)) '(1 3 4)
    assert-eq (xs.count) 5
    assert-eq (xs.count-matching (fn x -> gt? x 2)) 2
    assert-eq (xs.product) 48
    assert-eq (xs.take-while (fn x -> lt? x 3)) '(1 2 2)
    assert-eq (xs.drop-while (fn x -> lt? x 3)) '(3 4)
    assert-eq (xs.split-at 2) {'(1 2) '(2 3 4)}
    assert-eq (xs.partition (fn x -> eq? (mod x 2) 0)) {'(2 2 4) '(1 3)}
    assert-eq ([1 2].zip-with [10 20] &add) '(11 22)
    assert-eq ([1 2 3].intersperse :x) '(1 :x 2 :x 3)
    assert-eq (xs.with-index) '({1 0} {2 1} {2 2} {3 3} {4 4})
    assert-eq (xs.dedup) '(1 2 3 4)
    assert-eq (xs.uniq) '(1 2 3 4)
    assert-eq (xs.frequencies) %{1 1 2 2 3 1 4 1}
    assert-eq (xs.map-reduce 0 (fn x acc -> {(mul x 2) (add acc x)})) {'(2 4 4 6 8) 12}
    assert-eq ([1 2 3].scanl 0 &add) '(1 3 6)
    assert-eq ([3 1 2].min-max) {1 3}
    assert-eq ([:a :b :c].join-values ",") "a,b,c"
  end
  test "enum-each-effects-and-error-surfaces" do
    parent = self
    assert-eq ([1 2].each (fn x -> send parent {:enum-each x})) :ok
    assert-eq (receive do {:enum-each x} -> x end) 1
    assert-eq (receive do {:enum-each x} -> x end) 2
    match (assert-raises (fn do '().min-of end)) do
      {:error {:no-clause _ _}} -> :ok
    end
    match (assert-raises (fn do '().max-of end)) do
      {:error {:no-clause _ _}} -> :ok
    end
  end
end

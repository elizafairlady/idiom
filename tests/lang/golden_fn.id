use std/test
activate Test

suite do
  test "fn-clause-multiarg" do
    got = do
      f = fn do
        a 0 -> a
        a b -> add a b
      end
      {(f 7 0) (f 3 4)}
    end
    assert-inspect got "{7 7}"
  end
  test "fn-literal" do
    got = do
      inc = fn x -> add x 1; inc 41
    end
    assert-inspect got "42"
  end
  test "fn-value-hof" do
    got = do
      use std/enum
      square = fn x -> mul x x
      [1 2 3 4].map &square
    end
    assert-inspect got "(1 4 9 16)"
  end
  test "fn-value-local" do
    got = do
      outer = fn z do
        loc = fn x -> mul x 2
        ref = &loc
        ref z
      end
      outer 21
    end
    assert-inspect got "42"
  end
  test "fn-multiarg-bind-rhs" do
    got = do
      f = fn a b -> add a b
      g = fn a b c -> add a (add b c)
      {(f 40 2) (g 38 2 2)}
    end
    assert-inspect got "{42 42}"
  end
  test "defn-forward-ref-block" do
    got = do
      defn a x -> b (add x 1)
      m = 10
      defn b x -> c (add x m)
      n = 100
      defn c x -> add x n
      a 0
    end
    assert-inspect got "111"
  end
end

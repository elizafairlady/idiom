use std/test
activate Test

suite do
  test "repl-compile-requires-session" do
    got = try do repl-compile "1"; rescue r -> r end
    assert-inspect got "{:error {:runtime \"repl-compile requires a session context\"}}"
  end
  test "repl-abort-requires-session" do
    got = try do repl-abort 1; rescue r -> r end
    assert-inspect got "{:error {:runtime \"repl-abort requires a session context\"}}"
  end
  test "repl-spawn-requires-session" do
    got = try do repl-spawn (fn -> 1); rescue r -> r end
    assert-inspect got "{:error {:runtime \"repl-spawn requires a session context\"}}"
  end
  test "repl-diagnostic-requires-session" do
    got = try do repl-diagnostic; rescue r -> r end
    assert-inspect got "{:error {:runtime \"repl-diagnostic requires a session context\"}}"
  end
  test "ish-session-nil-outside-interactive-ish" do
    assert-inspect (ish-session) ":nil"
  end
end

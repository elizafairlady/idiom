use std/test
activate Test

defmacro twin-a %`(twin-a %,e) -> %`(add %,e 1)
defmacro twin-b %`(twin-b %,e) -> %`(add %,e 1)

suite do
  test "bare operator over provider operator shadows like any rebind" do
    got = do
      use tests/pkg/exporter
      activate Exporter
      operator <+> precedence: 50 assoc: left capture: :infix -> sub
      3 <+> 4
    end
    assert-inspect got "-1"
  end
  test "bare defmacro over provider macro shadows like any rebind" do
    got = do
      use tests/pkg/exporter
      activate Exporter
      defmacro answer stx -> make-syntax-int stx 5
      answer x
    end
    assert-eq got 5
  end
  test "provider over bare operator collides naming the unit" do
    assert-expand-error "use tests/pkg/exporter\noperator <+> precedence: 50 assoc: left capture: :infix -> sub\nactivate Exporter\n3 <+> 4" "surface '<+>' from '<expand-check>' is already active in this context"
  end
  test "provider over bare defmacro collides naming the unit" do
    assert-expand-error "use tests/pkg/exporter\ndefmacro answer stx -> make-syntax-int stx 5\nactivate Exporter\nanswer x" "surface 'answer' from '<expand-check>' is already active in this context"
  end
  test "expander-register-macro is not public surface" do
    assert-expand-error "expander-register-macro %'answer (fn s -> make-syntax-int s 5)" "unbound identifier 'expander-register-macro'"
  end
  test "expander-surface is not public surface" do
    assert-expand-error "expander-surface :operators" "unbound identifier 'expander-surface'"
  end
  test "provider over provider still collides naming the provider" do
    assert-expand-error "use tests/pkg/exporter\nuse tests/pkg/exporter2\nactivate Exporter\nactivate Exporter2\nanswer x" "is already active in this context"
  end
  test "separate defmacro expands identically" do
    assert-inspect {(twin-a 20) (twin-b 20)} "{21 21}"
  end
  test "separate defmacro keeps definition-site add under caller shadow" do
    got = do
      defn add a b -> :shadow
      {(twin-a 1) (twin-b 1)}
    end
    assert-inspect got "{2 2}"
  end
  test "defmacro extent ends at block exit" do
    assert-expand-error "do\n  defmacro def-in-block stx -> make-syntax-int stx 7\n  def-in-block q\nend\ndef-in-block q" "unbound identifier 'def-in-block'"
  end
  test "bare rebind in same unit stays legal after threading" do
    got = do
      defmacro rb stx -> make-syntax-int stx 1
      defmacro rb stx -> make-syntax-int stx 2
      rb q
    end
    assert-eq got 2
  end
  test "bare operator rebind in same unit stays legal" do
    got = do
      operator <+!> precedence: 50 assoc: left capture: :infix -> add
      operator <+!> precedence: 50 assoc: left capture: :infix -> sub
      3 <+!> 4
    end
    assert-inspect got "-1"
  end
end

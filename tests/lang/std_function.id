use std/test
activate Test
import std/function as Fn

defn church-zero -> fn _f -> fn x -> x

defn church-succ n -> fn f -> fn x -> f ((n f) x)

defn church-add a b -> fn f -> fn x -> (a f) ((b f) x)

defn church-mul a b -> fn f -> a (b f)

defn church-pow a b -> b a

defn church->int n -> (n (fn k -> k + 1)) 0

suite do
  test "function-core-combinators" do
    assert-eq (:x |> Fn.identity) :x
    k = Fn.const :kept
    assert-eq (k :ignored) :kept
    assert-eq (:start |> Fn.pipe (fn _ -> :piped)) :piped
    assert-eq (:start |> Fn.then (fn _ -> :then)) :then
    assert-eq ((Fn.flip &sub) 3 10) 7
    add1-after-double = Fn.compose (fn x -> x + 1) (fn x -> x * 2)
    assert-eq (add1-after-double 10) 21
    curried = Fn.curry2 &add
    assert-eq ((curried 40) 2) 42
    assert-eq ((Fn.uncurry2 curried) 40 2) 42
    assert-eq ({40 2} |> Fn.apply2 &add) 42
  end

  test "tap-preserves-subject-and-runs-effect" do
    parent = self
    got = :payload |> Fn.tap (fn x -> send parent {:tapped x})
    assert-eq got :payload
    assert-eq (receive do {:tapped x} -> x end) :payload
  end

  test "church-numerals-compose-higher-order-functions" do
    zero = church-zero
    one = zero |> church-succ
    two = one |> church-succ
    three = two |> church-succ
    five = church-add two three
    six = church-mul two three
    eight = church-pow two three
    assert-eq (zero |> church->int) 0
    assert-eq (one |> church->int) 1
    assert-eq (five |> church->int) 5
    assert-eq (six |> church->int) 6
    assert-eq (eight |> church->int) 8
    assert-eq ((three (fn s -> "${s}!")) "x") "x!!!"
  end
end

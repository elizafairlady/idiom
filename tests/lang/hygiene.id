use std/test
activate Test

defn kadd a b -> add a b
defmacro twice %`(twice %,e) -> %`(kadd %,e %,e)
defn myadd a b -> add a b
operator <+> precedence: 50 assoc: left capture: :infix -> myadd

defmacro inc do
  %`(inc %,a) -> %`(add %,a 1)
end

defmacro defproto %`(defproto %,n %,b) -> %`do
  protocol %,n %,b
end
defmacro deftrait %`(deftrait %,n %,b) -> %`do
  trait %,n %,b
end
defproto Greets do
  export defmacro answer s -> (make-syntax-int s 99)
end
deftrait Sized do
  method size-of x
end

defmacro defrec %`(defrec %,n %,b) -> %`do
  record %,n %,b
end
defrec Pt do
  field x
end

suite do
  test "macro declared beside transformer" do
    assert-eq (inc 41) 42
  end
  test "protocol registered from a macro splice" do
    got = do
      activate Greets
      answer foo
    end
    assert-eq got 99
  end
  test "methods of a macro-spliced protocol" do
    got = do
      implement Sized on int do
        method size-of x -> 100
      end
      size-of 5
    end
    assert-eq got 100
  end
  test "record registered from a macro splice" do
    p = Pt 7
    assert-eq p.x 7
    assert-eq (cond (Pt? p) 1 0) 1
  end
  test "template references resolve at definition context" do
    r = do
      defn kadd a b -> 0
      twice 21
    end
    assert-eq r 42
  end
  test "operator targets resolve at declaration site" do
    r = do
      defn myadd a b -> 0
      1 <+> 2
    end
    assert-eq r 3
  end
  test "do-block shadowing stays local" do
    x = 1
    r = do
      x = 2
      x
    end
    assert-eq r 2
    assert-eq x 1
  end
  test "nested do shadowing" do
    a = 1
    r = do
      a = 2
      inner = do
        a = 3
        a
      end
      add (mul 10 a) inner
    end
    assert-eq r 23
    assert-eq a 1
  end
  test "closures capture do-locals" do
    g = do
      n = 21
      fn x -> add n x
    end
    assert-eq (g 21) 42
  end
end

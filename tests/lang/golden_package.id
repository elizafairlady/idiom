use std/test

suite do
  test "package-decl" do
    got = do
      package demo
      use std/enum
      sum (map (fn x -> mul x 2) [1 2 3])
    end
    assert-inspect got "12"
  end
  test "package-folder" do
    got = do
      use tests/pkg/mathx
      add (quad 5) (trip 4)
    end
    assert-inspect got "32"
  end
  test "package-macro-phase" do
    got = do
      use tests/pkg/macropriv
      phase-answer anything
    end
    assert-inspect got "77"
  end
  test "package-macro-private-runtime" do
    got = do
      use tests/pkg/macropriv
      inc-private 41
    end
    assert-inspect got "42"
  end
  test "package-private" do
    got = do
      use tests/pkg/secret
      reveal 5
    end
    assert-inspect got "51"
  end
end

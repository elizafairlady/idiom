use std/test
activate std/test
import std/result as Res

suite do
  test "result-constructors-and-predicates" do
    assert-eq (Res.ok 7) {:ok 7}
    assert-eq (Res.err :bad) {:error :bad}
    assert-eq ({:ok 1} |> Res.result?) :true
    assert-eq ({:error :x} |> Res.result?) :true
    assert-eq (:nope |> Res.result?) :false
    assert-eq ({:ok 1} |> Res.ok-result?) :true
    assert-eq ({:error :x} |> Res.ok-result?) :false
    assert-eq ({:error :x} |> Res.error-result?) :true
    assert-eq ({:ok 1} |> Res.error-result?) :false
  end

  test "result-transformations" do
    assert-eq ({:ok 2} |> Res.map (fn x -> x + 1)) {:ok 3}
    assert-eq ({:error :bad} |> Res.map (fn x -> x + 1)) {:error :bad}
    assert-eq ({:error 4} |> Res.map-error (fn x -> x + 10)) {:error 14}
    assert-eq ({:ok 5} |> Res.map-error (fn x -> x + 10)) {:ok 5}
    assert-eq ({:ok 2} |> Res.and-then (fn x -> Res.ok (x * 3))) {:ok 6}
    assert-eq ({:error :bad} |> Res.and-then (fn x -> Res.ok (x * 3))) {:error :bad}
    assert-eq ({:ok 2} |> Res.or-else (fn _ -> Res.ok 9)) {:ok 2}
    assert-eq ({:error :bad} |> Res.or-else (fn _ -> Res.ok 9)) {:ok 9}
  end

  test "result-unwrapping-and-list-conversion" do
    assert-eq ({:ok 2} |> Res.unwrap!) 2
    assert-eq (assert-raises (fn do {:error :bad} |> Res.unwrap! end)) {:error :bad}
    assert-eq ({:ok 2} |> Res.unwrap-or 9) 2
    assert-eq ({:error :bad} |> Res.unwrap-or 9) 9
    assert-eq ({:ok :x} |> Res.to-list) '(:x)
    assert-eq ({:error :bad} |> Res.to-list) '()
  end

  test "result-rejects-non-result-tuples" do
    assert-eq (assert-raises (fn do {:maybe 1} |> Res.map (fn x -> x) end)) {:error {:bad-result {:maybe 1}}}
    assert-eq (assert-raises (fn do :nope |> Res.map-error (fn x -> x) end)) {:error {:bad-result :nope}}
    assert-eq (assert-raises (fn do :nope |> Res.and-then (fn x -> x) end)) {:error {:bad-result :nope}}
    assert-eq (assert-raises (fn do :nope |> Res.or-else (fn x -> x) end)) {:error {:bad-result :nope}}
    assert-eq (assert-raises (fn do :nope |> Res.unwrap! end)) {:error {:bad-result :nope}}
    assert-eq (assert-raises (fn do :nope |> Res.unwrap-or :x end)) {:error {:bad-result :nope}}
    assert-eq (assert-raises (fn do :nope |> Res.to-list end)) {:error {:bad-result :nope}}
  end
end

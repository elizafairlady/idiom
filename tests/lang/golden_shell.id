use std/test
use std/system with [cd env-set pwd]
activate Test

suite do
  test "shell-cd-relative" do
    got = do
      cd "/tmp"
      cd ".."
      pwd
    end
    assert-inspect got "\"/\""
  end
  test "shell-cd-rescue" do
    got = do
      try do
        cd "/zzz-does-not-exist"
        :unreachable
        rescue r -> :caught
      end
    end
    assert-inspect got ":caught"
  end
  test "shell-cd-bare-words-and-home" do
    got = do
      start = pwd
      env-set "HOME" start
      use app/ish
      activate Shell
      cd tests
      here = pwd
      cd ..
      back = pwd
      cd ~
      home = pwd
      cd tests
      cd
      noarg = pwd
      cd ./tests
      dot = pwd
      cd ../tests
      parent = pwd
      {(eq? here "${start}/tests") (eq? back start) (eq? home start) (eq? noarg start) (eq? dot "${start}/tests") (eq? parent "${start}/tests")}
    end
    assert-inspect got "{:true :true :true :true :true :true}"
  end
  test "shell-env-prefix" do
    got = do
      use app/ish
      activate Shell
      x = ISH_GOLD_PREFIX=hello printenv ISH_GOLD_PREFIX
      x
    end
    assert-inspect got "{:ok 0 \"hello\\n\" \"\"}"
  end
  test "shell-fd-dup" do
    got = do
      use app/ish
      activate Shell
      x = sh -c "echo oops >&2" 2>&1
      x
    end
    assert-inspect got "{:ok 0 \"oops\\n\" \"\"}"
  end
  test "shell-glob-nomatch" do
    got = do
      use app/ish
      activate Shell
      x = echo *.zzz-no-match
      x
    end
    assert-inspect got "{:ok 0 \"*.zzz-no-match\\n\" \"\"}"
  end
  test "shell-glob-quoted" do
    got = do
      use app/ish
      activate Shell
      x = echo "*.zzz-no-match"
      x
    end
    assert-inspect got "{:ok 0 \"*.zzz-no-match\\n\" \"\"}"
  end
  test "shell-word-join" do
    got = do
      use app/ish
      activate Shell
      x = echo a"b"c
      x
    end
    assert-inspect got "{:ok 0 \"abc\\n\" \"\"}"
  end
  test "shell-command-substitution" do
    got = do
      use app/ish
      activate Shell
      a = echo $(printf hi)
      b = echo pre$(printf hi)post
      c = echo $(printf a)$(printf b)
      d = ISH_GOLD_CS=$(printf env) printenv ISH_GOLD_CS
      {a b c d}
    end
    assert-inspect got "{{:ok 0 \"hi\\n\" \"\"} {:ok 0 \"prehipost\\n\" \"\"} {:ok 0 \"ab\\n\" \"\"} {:ok 0 \"env\\n\" \"\"}}"
  end
  test "shell-heredoc-sentinel" do
    got = do
      use app/ish
      activate Shell
      cat << EOF hello EOF
    end
    assert-inspect got "{:ok 0 \"hello\\n\" \"\"}"
  end
  test "word-syntax-requires-core-syntax" do
    assert-expand-error "\$(echo hi)" "word syntax requires core syntax"
  end
end

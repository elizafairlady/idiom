use std/test
implement std/test

suite do
  test "shell-cd-relative" do
    got = do
      cd "/tmp"
      cd ".."
      pwd
    end
    assert-inspect got "\"/\""
  end
  test "shell-cd-rescue" do
    got = do
      try do
        cd "/zzz-does-not-exist"
        :unreachable
        rescue r -> :caught
      end
    end
    assert-inspect got ":caught"
  end
  test "shell-env-prefix" do
    got = do
      implement std/shell
      x = ISH_GOLD_PREFIX=hello printenv ISH_GOLD_PREFIX
      x
    end
    assert-inspect got "{:ok 0 \"hello\\n\" \"\"}"
  end
  test "shell-fd-dup" do
    got = do
      implement std/shell
      x = sh -c "echo oops >&2" 2>&1
      x
    end
    assert-inspect got "{:ok 0 \"oops\\n\" \"\"}"
  end
  test "shell-glob-nomatch" do
    got = do
      implement std/shell
      x = echo *.zzz-no-match
      x
    end
    assert-inspect got "{:ok 0 \"*.zzz-no-match\\n\" \"\"}"
  end
  test "shell-glob-quoted" do
    got = do
      implement std/shell
      x = echo "*.zzz-no-match"
      x
    end
    assert-inspect got "{:ok 0 \"*.zzz-no-match\\n\" \"\"}"
  end
  test "shell-word-join" do
    got = do
      implement std/shell
      x = echo a"b"c
      x
    end
    assert-inspect got "{:ok 0 \"abc\\n\" \"\"}"
  end
end

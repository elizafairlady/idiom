use std/test
activate Test
use std/enum
use std/regex

defn texts do
  '() -> '()
  '(h . t) -> cons (text-of h) (texts t)
end

suite do
  test "regex-literal-and-captures" do
    rx = r"a(b+)c"
    m = scan rx "xxabbbc"
    assert (regex? rx)
    assert-eq (regex? "a") :false
    assert (result? m)
    assert-eq (result? :not-result) :false
    assert-eq (text-of m) "abbbc"
    assert-eq m.text-of "abbbc"
    assert-eq (start-of m) 2
    assert-eq (end-of m) 7
    assert-eq (capture m 0) "abbbc"
    assert-eq (capture m 1) "bbb"
    assert-eq (capture-range m 0) {2 7}
    assert-eq (source-of rx) "a(b+)c"
    assert-eq (group-count rx) 1
    assert-inspect (group-names rx) "(:nil)"
    assert-inspect (captures m) "(\"bbb\")"
    assert-inspect m.captures "(\"bbb\")"
  end

  test "regex-ere-classes-alt-and-repetition" do
    m = scan r"([[:alpha:]]+|_+)[0-9]{2,3}" "--ab123--"
    assert-eq (text-of m) "ab123"
    assert-eq (r"([[:alpha:]]+|_+)[0-9]{2,3}".scan "--ab123--").text-of "ab123"
    assert-eq (capture m 1) "ab"
    assert-eq (text-of (scan r"\d+" "a12b")) "12"
    assert-eq (text-of (scan r"\w+" "++a_9")) "a_9"
  end

  test "regex-full-and-test" do
    assert (result? (scan-full r"a+" "aaa"))
    assert (result? (r"a+".scan-full "aaa"))
    assert-eq (scan-full r"a+" "aaab") :nil
    assert-eq (text-of (scan-at r"a+" "baa" 1)) "aa"
    assert-eq (scan-at r"a+" "baa" 0) :nil
    assert-eq (text-of (scan-from r"a+" "baa" 0)) "aa"
    assert-eq (scan-from r"a+" "bbb" 0) :nil
    assert-eq (test? r"[0-9]+" "abc123") :true
    assert-eq (r"[0-9]+".test? "abc123") :true
    assert-eq ("[0-9]+".test? "abc123") :true
    assert-eq (test? r"[0-9]+" "abc") :false
  end

  test "regex-scan-filter-edge-cases" do
    assert-eq (start-of (raw-scan-from r"" "abc" 2)) 2
    assert-eq (start-of (raw-scan-from r"" "abc" 99)) 3
    assert-eq (raw-scan-from r"^b" "a\nb" 0) :nil
    assert-eq (start-of (raw-scan-from (compile! "^b" '(:multiline)) "a\nb" 0)) 2
    assert-eq (text-of (raw-scan-from r"[A-Z]+" "xxABC" 0)) "ABC"
    assert-eq (text-of (raw-scan-from r"(?<=foo)bar" "xxfoobar" 0)) "bar"
    assert-eq (text-of (raw-scan-from r"^a|b" "xxb" 0)) "b"
    assert-eq (text-of (raw-scan-from r"(^a)?b" "xxb" 0)) "b"
    assert-eq (raw-scan-from r"z+" "aaaaaaaaaaaaaaaaaaaaaaaaaaaaaaaa" 0) :nil
    assert-eq (raw-test? r"^a|b" "xxb") :true
    assert-eq (raw-test? r"z+$" "aaaaaaaaaaaaaaaaaaaaaaaaaaaaaz") :true
    assert-eq (raw-test? r"z+$" "aaaaaaaaaaaaaaaaaaaaaaaaaaaaa") :false
  end

  test "regex-result-retains-subject-through-gc-and-copy" do
    defn build do
      0 acc -> acc
      n acc -> build (n - 1) (cons n acc)
    end
    m = do
      s = "12abc34"
      raw-scan-from r"[a-z]+" s 0
    end
    build 50000 '()
    assert-eq (text-of m) "abc"
    parent = self
    spawn (fn do
      send parent {:match (raw-scan-from r"[a-z]+" "99xyz00" 0)}
    end)
    receive do
      {:match copied} -> assert-eq (text-of copied) "xyz"
    end
  end

  test "regex-lookaround" do
    assert-eq (text-of (scan r"foo(?=bar)" "xxfoobar")) "foo"
    assert-eq (scan r"foo(?!bar)" "xxfoobar") :nil
    assert-eq (text-of (scan r"foo(?!bar)" "xxfoobaz")) "foo"
    assert-eq (text-of (scan r"(?<=foo)bar" "xxfoobar")) "bar"
    assert-eq (scan r"(?<!foo)bar" "xxfoobar") :nil
    assert-eq (text-of (scan r"(?<!foo)bar" "xxbar")) "bar"
  end

  test "regex-named-captures" do
    rx = r"(?<word>[a-z]+)-(?<num>[0-9]+)"
    m = scan rx "abc-123"
    assert-eq (capture-named m "word") "abc"
    assert-eq (capture-named m :num) "123"
    assert-inspect (group-names rx) "(\"word\" \"num\")"
    assert-inspect (captures m) "(\"abc\" \"123\")"
  end

  test "regex-compile-and-options" do
    assert-eq (source-of (compile! "\\d+")) "\\d+"
    match (compile "[") do
      {:error {:regex :compile _ _}} -> :ok
      other -> error {:expected-compile-error other}
    end
    assert-eq (test? (compile! "abc" '(:caseless)) "ABC") :true
    assert-eq (scan r"^b" "a\nb") :nil
    assert-eq (text-of (scan (compile! "^b" '(:multiline)) "a\nb")) "b"
    assert-inspect (options-of (compile! "x" '(:caseless :multiline :dotall))) "(:caseless :multiline :dotall)"
  end

  test "regex-scan-all-replace-split-escape" do
    assert-inspect (texts (r"[0-9]+".scan-all "a12b3")) "(\"12\" \"3\")"
    assert-eq (r"[0-9]+".sub "a12b3" "#") "a#b3"
    assert-eq (r"[0-9]+".sub-all "a12b3" "#") "a#b#"
    assert-eq (r"([a-z]+)([0-9]+)".sub "ab12" "$2-$1") "12-ab"
    assert-eq (r"(?<word>[a-z]+)".sub "abc" "\\k<word>!") "abc!"
    assert-inspect (r",".split-on "a,b,,c") "(\"a\" \"b\" \"\" \"c\")"
    assert-inspect (texts (r"^a|b".scan-all "xxb")) "(\"b\")"
    assert-eq (r"(?=b)".sub-all "ab" "-") "a-b"
    assert-inspect (r"(?=b)".split-on "ab") "(\"a\" \"\")"
    assert-eq (text-of (scan (compile! (escape "a+b")) "xxa+b")) "a+b"
  end

  test "regex-thompson-lowering-ambiguous-ere" do
    assert-eq (text-of (scan-full r"(a|aa)*" "aaaaaaaaaaaaaaaa")) "aaaaaaaaaaaaaaaa"
    assert-eq (text-of (scan r"(ab|a)b" "zab")) "ab"
    assert-eq (capture (scan r"(a|aa)+" "aaaa") 1) "a"
    assert-eq (text-of (scan r"(?<=a|ba)c" "xxbac")) "c"
    assert-eq (scan r"(?<!a|ba)c" "xxbac") :nil
  end
end

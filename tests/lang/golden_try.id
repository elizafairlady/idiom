use std/test

suite do
  test "try-combined" do
    got = do
      try do raise :oops; rescue r -> r; ensure :cleaned end
    end
    assert-inspect got ":oops"
  end
  test "try-ensure-reraise" do
    got = do
      try do try do raise :x; ensure 1 end; rescue r -> r end
    end
    assert-inspect got ":x"
  end
  test "try-error-tuple" do
    got = do
      try do error :bad; rescue r -> r end
    end
    assert-inspect got "{:error :bad}"
  end
  test "try-handler-reason" do
    got = do
      try do raise 5; rescue r -> add r 37 end
    end
    assert-inspect got "42"
  end
  test "try-no-error" do
    got = do
      try do add 40 2; rescue r -> 0 end
    end
    assert-inspect got "42"
  end
  test "try-rescue-runtime" do
    got = do
      try do div 1 0; rescue r -> r end
    end
    assert-inspect got "{:error \"division by zero in div\"}"
  end
  test "try-rescue-value" do
    got = do
      try do raise :boom; rescue r -> r end
    end
    assert-inspect got ":boom"
  end
end

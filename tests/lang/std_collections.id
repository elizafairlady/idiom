use std/test
activate std/test
use std/enum
import std/keyword as Kw
import std/set as Set
import std/range as Range
import std/vector as Vec
import std/tuple as Tup
import std/result as Res
import std/function as Fn
import std/math as Math

suite do
  test "keyword-lists" do
    kws = '({:a 1} {:b 2} {:a 3})
    assert-eq (Kw.keyword? kws) :true
    assert-eq (Kw.keyword? '({:a 1} {"not-atom" 2})) :false
    assert-eq (Kw.keyword? :not-a-list) :false
    assert-eq (kws |> Kw.has? :a) :true
    assert-eq (kws |> Kw.has? :z) :false
    assert-eq (kws |> Kw.get :a) 1
    assert-eq (kws |> Kw.get :z) :nil
    assert-eq (kws |> Kw.get-or :z :default) :default
    assert-eq (kws |> Kw.get! :b) 2
    assert-eq (assert-raises (fn do kws |> Kw.get! :z end)) {:error {:key-not-found :z}}
    assert-eq (kws |> Kw.get-all :a) '(1 3)
    assert-eq (kws |> Kw.keys) '(:a :b :a)
    assert-eq (kws |> Kw.vals) '(1 2 3)
    assert-eq (kws |> Kw.delete :a) '({:b 2})
    assert-eq (kws |> Kw.put :a 9) '({:a 9} {:b 2})
    assert-eq (kws |> Kw.put-new :b 9) kws
    assert-eq (kws |> Kw.put-new :c 4) '({:c 4} {:a 1} {:b 2} {:a 3})
    assert-eq (kws |> Kw.delete-first :a) '({:b 2} {:a 3})
    assert-eq (kws |> Kw.pop :b) {2 '({:a 1} {:a 3})}
    assert-eq (kws |> Kw.pop-or :z :default) {:default kws}
    assert-eq (Kw.merge kws '({:a 9} {:c 4})) '({:b 2} {:a 9} {:c 4})
    assert-eq (Kw.to-map (Kw.merge-with '({:a 1} {:b 2}) '({:a 9} {:c 4}) (fn _k x y -> x + y))) %{:a 10 :b 2 :c 4}
    assert-eq (kws |> Kw.take '(:a :c)) '({:a 1} {:a 3})
    assert-eq (kws |> Kw.drop '(:a)) '({:b 2})
    assert-eq (Kw.to-map kws) %{:a 3 :b 2}
    assert-eq (Kw.to-map (Kw.from-map %{:x 1 :y 2})) %{:x 1 :y 2}
  end
  test "sets" do
    empty = (Set.empty)
    manual = Set.Set %{9 :true}
    a = Set.new '(1 2 2 3)
    b = Set.new '(3 4)
    assert-eq (empty |> Set.empty?) :true
    assert-eq (manual |> Set.has? 9) :true
    assert-eq (a |> Set.empty?) :false
    assert-eq (Set.to-list (Set.from-list '(3 3 2))).sort '(2 3)
    assert-eq (Set.size a) 3
    assert-eq (a |> Set.has? 2) :true
    assert-eq (a |> Set.has? 9) :false
    assert-eq (empty |> Set.add :x |> Set.has? :x) :true
    assert-eq (empty |> Set.add :x |> Set.del :x |> Set.empty?) :true
    assert-eq (Set.to-list (Set.union a b)).sort '(1 2 3 4)
    assert-eq (Set.to-list (Set.intersection a b)) '(3)
    assert-eq (Set.to-list (Set.difference a b)).sort '(1 2)
    assert-eq (Set.subset? (Set.new '(1 2)) a) :true
    assert-eq (Set.subset? b a) :false
    assert-eq (Set.disjoint? (Set.new '(:x)) a) :true
    assert-eq (Set.disjoint? (Set.new '(3 9)) a) :false
    assert-eq (Set.equal? (Set.new '(1 2 2)) (Set.new '(2 1))) :true
    assert-eq (Set.equal? (Set.new '(1 2)) (Set.new '(1 3))) :false
    assert-eq (Set.to-list (Set.filter a (fn x -> neq? x 2))).sort '(1 3)
    assert-eq (Set.to-list (Set.map a (fn x -> mod x 2))).sort '(0 1)
    assert-eq (a.map (fn x -> add x 10)).sort '(11 12 13)
    assert-eq a.length 3
  end
  test "ranges" do
    r = Range.new 1 5
    manual = Range.Range 2 8 3 :true
    down = Range.inclusive 5 1 -2
    empty = Range.new 5 1
    assert-eq (Range.to-list r) '(1 2 3 4)
    assert-eq (Range.to-list manual) '(2 5 8)
    assert-eq r.to-list '(1 2 3 4)
    assert-eq down.to-list '(5 3 1)
    assert-eq (Range.to-list (Range.exclusive 5 1 -2)) '(5 3)
    assert-eq (Range.to-list (Range.inclusive 1 5 2)) '(1 3 5)
    assert-eq (empty |> Range.empty?) :true
    assert-eq (Range.first empty) :nil
    assert-eq (Range.last empty) :nil
    assert-eq (Range.size empty) 0
    assert-eq (Range.reduce r 0 &add) 10
    assert-eq (Range.size r) 4
    assert-eq (Range.first r) 1
    assert-eq (Range.last r) 4
    assert-eq (Range.contains? r 4) :true
    assert-eq (Range.contains? r 5) :false
    assert-eq (Range.contains? (Range.inclusive 1 5 2) 4) :false
    assert-eq (assert-raises (fn do Range.new 1 5 0 end)) {:error {:range-step-zero}}
  end
  test "vector-and-tuple-wrappers" do
    v = [1 2 3]
    assert-eq (Vec.to-list v) '(1 2 3)
    assert-eq (Vec.from-list '(1 2 3)) v
    assert-eq (Vec.empty? []) :true
    assert-eq (Vec.empty? v) :false
    assert-eq (Vec.length v) 3
    assert-eq (Vec.nth v 1) 2
    assert-eq (Vec.nth v (neg 1)) :nil
    assert-eq (Vec.nth v 99) :nil
    assert-eq (Vec.nth-or v 99 :missing) :missing
    assert-eq (Vec.nth! v 2) 3
    assert-eq (assert-raises (fn do Vec.nth! v 99 end)) {:error {:index-out-of-range 99}}
    assert-eq (Vec.map [1 2 3] (fn x -> add x 1)) [2 3 4]
    assert-eq (Vec.filter [1 2 3 4] (fn x -> eq? (mod x 2) 0)) [2 4]
    assert-eq (Vec.reverse v) [3 2 1]
    assert-eq (Vec.append [1 2] 3) [1 2 3]
    assert-eq (Vec.concat [1 2] [3 4]) [1 2 3 4]
    assert-eq (Vec.take v 2) [1 2]
    assert-eq (Vec.drop v 1) [2 3]
    assert-eq (Vec.slice [0 1 2 3] 1 3) [1 2]
    assert-eq (Vec.delete-at v 1) [1 3]
    assert-eq (Vec.insert-at [1 3] 1 2) [1 2 3]
    assert-eq (Vec.replace-at v 1 :x) [1 :x 3]
    assert-eq (Vec.update-at [1 2] 1 (fn x -> mul x 10)) [1 20]
    t = {1 2 3}
    assert-eq (Tup.to-list t) '(1 2 3)
    assert-eq (Tup.from-list '(1 2 3)) t
    assert-eq (Tup.empty? {}) :true
    assert-eq (Tup.empty? t) :false
    assert-eq (Tup.length t) 3
    assert-eq (Tup.nth t 1) 2
    assert-eq (Tup.nth t (neg 1)) :nil
    assert-eq (Tup.nth t 99) :nil
    assert-eq (Tup.nth-or t 99 :missing) :missing
    assert-eq (Tup.nth! t 2) 3
    assert-eq (assert-raises (fn do Tup.nth! t 99 end)) {:error {:index-out-of-range 99}}
    assert-eq (Tup.map {1 2} (fn x -> add x 10)) {11 12}
    assert-eq (Tup.reverse t) {3 2 1}
    assert-eq (Tup.append {1 2} 3) {1 2 3}
    assert-eq (Tup.concat {1 2} {3 4}) {1 2 3 4}
    assert-eq (Tup.take t 2) {1 2}
    assert-eq (Tup.drop t 1) {2 3}
    assert-eq (Tup.slice {0 1 2 3} 1 3) {1 2}
    assert-eq (Tup.delete-at {1 2 3} 1) {1 3}
    assert-eq (Tup.insert-at {1 3} 1 2) {1 2 3}
    assert-eq (Tup.replace-at t 1 :x) {1 :x 3}
    assert-eq (Tup.update-at {1 2} 1 (fn x -> mul x 10)) {1 20}
  end
  test "result-function-and-math" do
    assert-eq (Res.map {:ok 2} (fn x -> add x 1)) {:ok 3}
    assert-eq (Res.map {:error :bad} (fn x -> add x 1)) {:error :bad}
    assert-eq (Res.unwrap-or {:error :bad} 9) 9
    c = Fn.compose (fn x -> add x 1) (fn x -> mul x 2)
    assert-eq (c 10) 21
    assert-eq (Fn.tap :x (fn _ -> :ok)) :x
    assert-eq (Math.even? 4) :true
    assert-eq (Math.odd? 5) :true
    assert-eq (Math.gcd 54 24) 6
    assert-eq (Math.lcm 6 8) 24
    assert-eq (Math.clamp 12 0 10) 10
  end
  test "generic-compare" do
    assert-eq (compare '(1 2) '(1 3)) :lt
    assert-eq (compare %{:b 2 :a 1} %{:a 1 :b 2}) :eq
    assert-eq (compare {1 "b"} {1 "a"}) :gt
    assert-eq ["b" "a" "c"].sort-compare '("a" "b" "c")
  end
end

w ~ %
s sh -c "kill -TSTP 0; while ! test -f release; do sleep 0.05; done; sleep 0.5; echo one > one"
s \r
w [1]+  Stopped
s sh -c "kill -TSTP 0; echo two > two"
s \r
w [2]+  Stopped
s bg 1
s \r
w [1]+ sh -c "kill -TSTP 0; while ! test -f release; do sleep 0.05; done; sleep 0.5; echo one > one" &
s fg 2
s \r
w sh -c "kill -TSTP 0; echo two > two"
w ~ %
s touch release
s \r
s fg 1
s \r
w sh -c "kill -TSTP 0; while ! test -f release; do sleep 0.05; done; sleep 0.5; echo one > one"
s add 0 0
s \r
s jobs
s \r
p 100
s fg 9
s \r
w no-such-job
s sleep 0.1 &
s \r
w [1] sleep 0.1 &
s exit 0
s \r

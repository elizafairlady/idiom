#!/usr/bin/env ish
mkdir -p build/shell-words
cd "build/shell-words"
echo joined output > out1.txt
cat out1.txt
echo appended >> out1.txt
cat out1.txt
env-set "SW" "mid"
echo pre$SW.post
echo --flag=$SW
echo https://example.com/a?b
echo host:path
echo abc"def"
FOO=bar printenv FOO
FOO= printenv FOO
sh -c "echo oops >&2" 2> err.log
cat err.log
rm -f out1.txt err.log

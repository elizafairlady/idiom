use std/port with [port-close-input port-read port-write]
use std/string
use std/test
import std/cmd as Cmd
activate Test

printf-ok-graph = Cmd.command (list "printf" "ok") (Cmd.stdio :null :pipe :null)
cat-graph = Cmd.command (list "cat") (Cmd.stdio :pipe :pipe :null)

suite "actor-port" do
  bench "actor/spawn-send-receive" expect: 1 do
    parent = self
    spawn (fn do
      send parent {:bench 1}
    end)
    receive do
      {:bench value} -> value
      after 1000 -> 0
    end
  end

  bench "actor/spawn-monitor-down" expect: 1 do
    {_pid ref} = spawn-monitor (fn -> 1)
    receive do
      {:down r _p :normal} when (eq? r ref) -> 1
      after 1000 -> 0
    end
  end

  bench "port/spawn-monitor" expect: 1 do
    p = spawn printf-ok-graph
    ref = monitor p
    done = receive do
      {:down r target :normal} when (and (eq? r ref) (eq? target p)) -> :ok
      after 1000 -> :timeout
    end
    match {done (port-read p :stdout 2)} do
      {:ok {:data "ok"}} -> 1
      _ -> 0
    end
  end

  bench "port/pipe-write-read" expect: 1 do
    p = spawn cat-graph
    port-write p "ok"
    port-close-input p
    match (port-read p :stdout 2) do
      {:data "ok"} -> 1
      _ -> 0
    end
  end
end
:ok

package pydiom_reader

grammar PythonishReader exclusive do
  skip space {:regex "[ \t]+"}
  token newline {:literal "\n"} -> {:emit-atom newline}
  token block {:literal "block"} -> {:emit-word block}
  token colon {:literal ":"} -> {:emit-atom colon}
  token equals {:literal "="} -> {:emit-word "="}
  token plus {:literal "+"} -> {:emit-word "+"}
  token integer {:regex "[0-9]+"} -> {:capture integer}
  token ident {:regex "[A-Za-z_][A-Za-z0-9_]*"} -> {:capture ident}
  form term {:alt {:capture value {:token integer}} {:capture value {:token ident}}} -> {:capture value}
  form assign_stmt {:seq {:capture name {:token ident}} {:token equals} {:capture value {:ref term}}} -> {:emit-form "%-expr" [{:capture name} {:emit-word "="} {:capture value}]}
  form plus_stmt {:seq {:capture left {:ref term}} {:token plus} {:capture right {:ref term}}} -> {:emit-form "%-expr" [{:capture left} {:emit-word "+"} {:capture right}]}
  form stmt {:alt {:capture item {:ref assign_stmt}} {:capture item {:ref plus_stmt}}} -> {:capture item}
  form indented_stmt {:seq {:indent-gt block_head {:capture item {:ref stmt}}} {:repeat {:token newline}}} -> {:capture item}
  form program {:seq {:capture block_head {:token block}} {:token colon} {:token newline} {:repeat {:capture stmt {:ref indented_stmt}}}} -> {:emit-form "%-package-begin" [{:emit-form "%-expr" [{:emit-form "%-body" [{:splice stmt}]}]}]}
end

core-reader :source PythonishReader

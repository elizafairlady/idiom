package coregrammar_surface

export protocol GrammarSurface do
  grammar ReaderSurfaceDo extend do
    skip space {:regex " +"}
    token ident {:regex "[A-Za-z_][A-Za-z0-9_]*"} -> {:capture ident}
    form word {:capture ident {:ref ident}} -> {:emit-form "%-expr" [{:capture ident}]}
    form program {:capture item {:ref word}} -> {:emit-form "%-package-begin" [{:capture item}]}
  end
end

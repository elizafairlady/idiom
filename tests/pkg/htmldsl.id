export protocol HtmlDsl do
  core-syntax _ do
    %`(%,tag %,@parts) -> do
      defn body? do
        p when (syntax-list? p) ->
          and (gt? (syntax-length p) 0) (syntax-word? (syntax-nth p 0)) (eq? (syntax-word-text (syntax-nth p 0)) "%-body")
        _ -> :false
      end

      defn attr-dict? p -> eq? (syntax-kind p) :dict

      defn body-children do
        b i n when (eq? i n) -> '()
        b i n -> cons (syntax-nth b i) (body-children b (add i 1) n)
      end

      defn dict-attrs do
        d i n when (eq? i n) -> '()
        d i n ->
          cons %`(str " " %,(make-syntax-string tag (syntax-atom-text (syntax-nth d i))) "=\"" %,(syntax-nth d (add i 1)) "\"") (dict-attrs d (add i 2) n)
      end

      defn attrs-of do
        '(a . t) when (attr-dict? a) -> append (dict-attrs a 0 (syntax-length a)) (attrs-of t)
        '(a v . t) when (syntax-atom? a) ->
          cons %`(str " " %,(make-syntax-string tag (syntax-atom-text a)) "=\"" %,v "\"") (attrs-of t)
        '(_ . t) -> attrs-of t
        '() -> '()
      end

      defn kids-of do
        '(a . t) when (attr-dict? a) -> kids-of t
        '(a _ . t) when (syntax-atom? a) -> kids-of t
        '(b . t) when (body? b) -> append (body-children b 1 (syntax-length b)) (kids-of t)
        '(c . t) -> cons c (kids-of t)
        '() -> '()
      end

      tag-text = make-syntax-string tag (syntax-word-text tag)
      %`(str "<" %,tag-text %,@(attrs-of parts) ">" %,@(kids-of parts) "</" %,tag-text ">")
    end
  end
end

resolver form do
  defn parts-of do
    i n when (eq? i n) -> '()
    i n -> cons (syntax-nth form i) (parts-of (add i 1) n)
  end

  defn body? do
    p when (syntax-list? p) ->
      and (gt? (syntax-length p) 0) (syntax-word? (syntax-nth p 0)) (eq? (syntax-word-text (syntax-nth p 0)) "%-body")
    _ -> :false
  end

  defn attr-dict? do
    p -> eq? (syntax-kind p) :dict
  end

  defn body-children do
    b i n when (eq? i n) -> '()
    b i n -> cons (syntax-nth b i) (body-children b (add i 1) n)
  end

  defn dict-attrs do
    d i n when (eq? i n) -> '()
    d i n ->
      cons %`(str " " %,(make-syntax-string form (syntax-atom-text (syntax-nth d i))) "=\"" %,(syntax-nth d (add i 1)) "\"") (dict-attrs d (add i 2) n)
  end

  defn attrs-of do
    (list a . t) when (attr-dict? a) -> append (dict-attrs a 0 (syntax-length a)) (attrs-of t)
    (list a v . t) when (syntax-atom? a) ->
      cons %`(str " " %,(make-syntax-string form (syntax-atom-text a)) "=\"" %,v "\"") (attrs-of t)
    (list _ . t) -> attrs-of t
    '() -> '()
  end

  defn kids-of do
    (list a . t) when (attr-dict? a) -> kids-of t
    (list a _ . t) when (syntax-atom? a) -> kids-of t
    (list b . t) when (body? b) -> append (body-children b 1 (syntax-length b)) (kids-of t)
    (list c . t) -> cons c (kids-of t)
    '() -> '()
  end

  tag = make-syntax-string form (syntax-word-text (syntax-nth form 1))
  parts = parts-of 2 (syntax-length form)
  %`(str "<" %,tag %,@(attrs-of parts) ">" %,@(kids-of parts) "</" %,tag ">")
end

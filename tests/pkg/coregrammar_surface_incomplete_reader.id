package coregrammar_surface_incomplete_reader

grammar ReaderSurfaceIncomplete exclusive do
  skip space {:regex " +"}
  token ident {:regex "[A-Za-z_][A-Za-z0-9_]*"} -> {:capture ident}
  form word {:capture ident {:ref ident}} -> {:emit-form "%-expr" [{:capture ident}]}
end

core-reader :source ReaderSurfaceIncomplete

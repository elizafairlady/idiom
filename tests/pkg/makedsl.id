package makedsl

export defmacro rule stx do
  n = syntax-length stx
  defn deps-of do
    _ when (gt? n 5) -> syntax-nth stx 4
    _ -> %`(list)
  end
  %`(tuple :rule %,(syntax-nth stx 2) %,(deps-of 0) (fn _ig %,(syntax-nth stx (sub n 1))))
end

export defn rule-name do
  {:rule n _ _} -> n
end

defn find-rule do
  [{:rule n d a} . _] name when (eq? n name) -> tuple :rule n d a
  [_ . t] name -> find-rule t name
  :nil name -> error (tuple :unknown-target name)
end

defn done? do
  :nil _ -> :false
  [{n _} . t] name -> cond (eq? n name) :true (done? t name)
end

defn build-list do
  rules :nil done -> done
  rules [d . ds] done -> build-list rules ds (build-into rules d done)
end

defn build-into do
  rules name done when (done? done name) -> done
  rules name done ->
    match (find-rule rules name) do
      {:rule n deps action} -> do
        finished = build-list rules deps done
        append finished (cons (tuple n (action :go)) :nil)
      end
    end
end

export defn build rules name -> build-into rules name :nil

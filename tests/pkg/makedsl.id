package makedsl

export defmacro rule stx do
  n = syntax-length stx
  defn dict-get do
    d i n key when (eq? i n) -> %`'()
    d i n key when (eq? (syntax-atom-text (syntax-nth d i)) key) -> syntax-nth d (add i 1)
    d i n key -> dict-get d (add i 2) n key
  end
  defn deps-of do
    _ when (eq? (syntax-kind (syntax-nth stx 3)) :dict) ->
      dict-get (syntax-nth stx 3) 0 (syntax-length (syntax-nth stx 3)) "deps"
    _ -> %`'()
  end
  %`{:rule %,(syntax-nth stx 2) %,(deps-of 0) (fn %,(syntax-nth stx (sub n 1)))}
end

export defn rule-name do
  {:rule n _ _} -> n
end

defn find-rule do
  (list {:rule n d a} . _) name when (eq? n name) -> {:rule n d a}
  (list _ . t) name -> find-rule t name
  '() name -> error {:unknown-target name}
end

defn done? do
  '() _ -> :false
  (list {n _} . t) name -> cond (eq? n name) :true (done? t name)
end

defn build-list do
  rules '() done -> done
  rules (list d . ds) done -> build-list rules ds (build-into rules d done)
end

defn build-into do
  rules name done when (done? done name) -> done
  rules name done ->
    match (find-rule rules name) do
      {:rule n deps action} -> do
        finished = build-list rules deps done
        append finished (cons {n action} '())
      end
    end
end

export defn build rules name -> build-into rules name '()

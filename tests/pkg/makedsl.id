package makedsl

export protocol MakeDsl do
  export defmacro rule do
    %`(rule %,name %{:deps %,deps} do %,@body end) -> %`{:rule %,name %,deps (fn do %,@body end)}
    %`(rule %,name do %,@body end) -> %`{:rule %,name '() (fn do %,@body end)}
  end
end

export defn rule-name do
  {:rule n _ _} -> n
end

defn find-rule do
  (list {:rule n d a} . _) name when (eq? n name) -> {:rule n d a}
  (list _ . t) name -> find-rule t name
  '() name -> error {:unknown-target name}
end

defn done? do
  '() _ -> :false
  (list {n _} . t) name -> cond (eq? n name) :true (done? t name)
end

defn build-list do
  rules '() done -> done
  rules (list d . ds) done -> build-list rules ds (build-into rules d done)
end

defn build-into do
  rules name done when (done? done name) -> done
  rules name done ->
    match (find-rule rules name) do
      {:rule n deps action} -> do
        finished = build-list rules deps done
        append finished (cons {n action} '())
      end
    end
end

export defn build rules name -> build-into rules name '()

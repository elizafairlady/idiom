use std/port with [port-close-input port-read port-status port-write]

defn wait-done do
  _p 0 -> :timeout
  p n -> match (port-status p) do
    :done -> :ok
    _ -> receive do
      {:never x} -> x
      after 10 -> wait-done p (sub n 1)
    end
  end
end

p = exec {:exec {:stage (list {:lit "cat"}) '() '()} {:stdio :pipe :pipe :pipe}}
me = self
_writer = spawn (fn -> receive do
  {:never x} -> x
  after 10 -> send me {:write (port-write p "hello\n")}
end)
data = port-read p :stdout 1024
w = receive do
  {:write r} -> r
end
closed = port-close-input p
result = await p

p2 = exec {:exec {:stage (list {:lit "printf"} {:lit "done"}) '() '()} {:stdio :null :pipe :pipe}}
waited = wait-done p2 50
after_done = port-read p2 :stdout 1024
eof = port-read p2 :stdout 1024
result2 = await p2

println {w data closed result waited after_done eof result2}

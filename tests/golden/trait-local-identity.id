mk-a = fn _ig do
  trait P do
    method size x
  end
  implement P on int do
    method size n -> 111
  end
  size 5
end
mk-b = fn _ig do
  trait P do
    method size x
  end
  implement P on string do
    method size s -> 222
  end
  size "hello"
end
mk-c = fn _ig do
  trait P do
    method size x
  end
  implement P on string do
    method size s -> 222
  end
  size 5
end
println (mk-a 0)
println (mk-b 0)
println (try do
  mk-c 0
  rescue _r -> :no-cross-dispatch
end)

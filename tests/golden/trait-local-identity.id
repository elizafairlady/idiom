mk-a = fn do
  trait P do
    method size x
  end
  implement P on int do
    method size n -> 111
  end
  size 5
end
mk-b = fn do
  trait P do
    method size x
  end
  implement P on string do
    method size s -> 222
  end
  size "hello"
end
mk-c = fn do
  trait P do
    method size x
  end
  implement P on string do
    method size s -> 222
  end
  size 5
end
println (mk-a)
println (mk-b)
println (try do
  mk-c
  rescue _r -> :no-cross-dispatch
end)

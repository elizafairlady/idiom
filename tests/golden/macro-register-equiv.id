defmacro twin-a %`(twin-a %,e) -> %`(add %,e 1)
defmacro mk-twin do
  %`(mk-twin %,n) -> do
    expander-register-macro n (fn do %`(_ %,e) -> %`(add %,e 1) end)
    %`:nil
  end
end
mk-twin twin-b
shadowed = do
  defn add a b -> :shadow
  {(twin-a 1) (twin-b 1)}
end
{(twin-a 20) (twin-b 20) shadowed}

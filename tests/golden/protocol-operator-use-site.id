protocol OpCarrier do
  defn opmul a b -> mul a b
  operator <%%> precedence: 50 assoc: left capture: infix -> opmul
end
protocol UsesOp do
  export defmacro squarish stx do syntax-case stx do
    (_ x) -> %`(%,x <%%> %,x)
  end end
end
r = do
  activate OpCarrier
  activate UsesOp
  squarish 6
end
activate OpCarrier
activate UsesOp
println (squarish 7)
inspect r

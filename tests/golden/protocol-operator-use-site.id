protocol OpCarrier do
  operator <%%> precedence: 50 assoc: left capture: :infix do
    a b -> mul a b
  end
end
protocol UsesOp do
  export defmacro squarish %`(squarish %,x) -> %`(%,x <%%> %,x)
end
r = do
  activate OpCarrier
  activate UsesOp
  squarish 6
end
activate OpCarrier
activate UsesOp
println (squarish 7)
inspect r

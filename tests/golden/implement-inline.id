r = do
  protocol Ops do
    operator <+!> precedence: 50 assoc: left capture: :infix do
      a b -> add (add a b) 1
    end
  end
  trait Size do
    method size x
  end
  activate Ops
  implement Size on int do
    method size n -> 111
  end
  {(size 5) (3 <+!> 4)}
end
s = do
  protocol Ops do
    operator <+!> precedence: 50 assoc: left capture: :infix do
      a b -> mul a b
    end
  end
  trait Size do
    method size x
  end
  activate Ops
  implement Size on int do
    method size n -> 222
  end
  {(size 5) (3 <+!> 4)}
end
println (inspect r)
println (inspect s)

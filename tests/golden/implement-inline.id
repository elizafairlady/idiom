r = do
  protocol Ops do
    defn opbump a b -> add (add a b) 1
    operator <+!> precedence: 50 assoc: left fixity: infix -> opbump
  end
  trait Size do
    method size x
  end
  activate Ops
  implement Size on int do
    method size n -> 111
  end
  {(size 5) (3 <+!> 4)}
end
s = do
  protocol Ops do
    defn opbump a b -> mul a b
    operator <+!> precedence: 50 assoc: left fixity: infix -> opbump
  end
  trait Size do
    method size x
  end
  activate Ops
  implement Size on int do
    method size n -> 222
  end
  {(size 5) (3 <+!> 4)}
end
println (inspect r)
inspect s

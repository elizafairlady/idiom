use std/regex

rx-comment = compile! "#[^\n]*"
rx-string = compile! "\"[^\"]*\""
rx-number = compile! "[0-9]+"
rx-word = compile! "[A-Za-z_][A-Za-z0-9_]*"

defn sample i n acc -> if (gte? i n) do
  acc
else do
  sample (add i 1) n "#{acc}def name_${i} = \"value${i}\" # comment ${i}\n"
end

defn choose best hit kind -> match hit do
  :nil -> best
  m -> do
    s = start-of m
    e = end-of m
    match best do
      :nil -> {s e kind}
      {bs _be _bk} when (lt? s bs) -> {s e kind}
      _ -> best
    end
  end
end

defn scan-one text pos do
  b1 = choose :nil (scan-from rx-comment text pos) 1
  b2 = choose b1 (scan-from rx-string text pos) 2
  b3 = choose b2 (scan-from rx-number text pos) 3
  choose b3 (scan-from rx-word text pos) 4
end

defn scan-loop text pos acc -> if (gte? pos (str-len text)) do
  acc
else do
  match (scan-one text pos) do
    :nil -> acc
    {s e kind} -> do
      acc2 = mod (add acc (add (mul s 3) (add (mul e 5) (mul kind 7)))) 1000000007
      scan-loop text (cond (gt? e s) e (add s 1)) acc2
    end
  end
end

defn rounds text i n acc -> if (gte? i n) do
  acc
else do
  rounds text (add i 1) n (mod (add acc (scan-loop text 0 0)) 1000000007)
end

text = sample 0 120 ""
println (rounds text 0 25 0)

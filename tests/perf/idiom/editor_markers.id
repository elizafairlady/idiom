defn imin do
  a b when (lt? a b) -> a
  _ b -> b
end

defn imax do
  a b when (gt? a b) -> a
  _ b -> b
end

defn make-spans i n acc -> if i >= n do
  acc
else do
  start = i * 13
  stop = start + 5 + (i % 7)
  make-spans (i + 1) n (cons {start stop (i % 5)} acc)
end

defn adjust-pos x pos del ins do
  del-end = pos + del
  after-del = cond (x <= pos) x (cond (x >= del-end) (x - del) pos)
  cond (after-del >= pos) (after-del + ins) after-del
end

defn adjust-span {a b k} pos del ins do
  {(adjust-pos a pos del ins) (adjust-pos b pos del ins) k}
end

defn adjust-spans do
  '() _pos _del _ins -> '()
  '(span . rest) pos del ins -> cons (adjust-span span pos del ins) (adjust-spans rest pos del ins)
end

defn score-spans do
  '() acc -> acc
  '(span . rest) acc -> do
    {a b k} = span
    score-spans rest ((acc + (a * 3) + (b * 5) + (k * 7)) % 1000000007)
  end
end

defn step i {spans doclen} do
  pos = ((i * 97) + (doclen / 3)) % doclen
  want-del = cond (i % 4 == 0) 3 1
  del = imin want-del (doclen - pos)
  ins = match (i % 5) do
    0 -> 0
    1 -> 1
    2 -> 4
    3 -> 2
    _ -> 0
  end
  {(adjust-spans spans pos del ins) (imax 1 ((doclen - del) + ins))}
end

defn loop i n state -> if i >= n do
  state
else do
  loop (i + 1) n (step i state)
end

{spans doclen} = loop 0 2500 {(make-spans 0 80 '()) 5000}
println (((score-spans spans 0) + (doclen * 11)) % 1000000007)

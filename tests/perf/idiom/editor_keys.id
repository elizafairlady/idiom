defn imin do
  a b when (a < b) -> a
  _ b -> b
end

defn imax do
  a b when (a > b) -> a
  _ b -> b
end

defn cmd-left st -> dict-put st :point (imax 0 ((dict-get st :point 0) - 1))
defn cmd-right st -> dict-put st :point (imin (dict-get st :size 0) ((dict-get st :point 0) + 1))
defn cmd-home st -> dict-put st :point 0
defn cmd-end st -> dict-put st :point (dict-get st :size 0)

defn cmd-insert st ->
  st
  |> dict-put :size ((dict-get st :size 0) + 1)
  |> dict-put :point ((dict-get st :point 0) + 1)
  |> dict-put :dirty ((dict-get st :dirty 0) + 1)

defn cmd-insert-fast st ->
  st
  |> dict-put :size ((dict-get st :size 0) + 2)
  |> dict-put :point ((dict-get st :point 0) + 2)
  |> dict-put :dirty ((dict-get st :dirty 0) + 1)

defn cmd-delete st do
  p = dict-get st :point 0
  n = dict-get st :size 0
  cond (p < n) (st |> dict-put :size (n - 1) |> dict-put :dirty ((dict-get st :dirty 0) + 1)) st
end

defn cmd-mark st -> dict-put st :marks ((dict-get st :marks 0) + (dict-get st :point 0))
defn cmd-recenter st -> dict-put st :dirty ((dict-get st :dirty 0) + ((dict-get st :point 0) % 7))
defn cmd-indent st ->
  st
  |> dict-put :point (imin (dict-get st :size 0) ((dict-get st :point 0) + 2))
  |> dict-put :dirty ((dict-get st :dirty 0) + 1)

base-map = %{:left &cmd-left :right &cmd-right :insert &cmd-insert :delete &cmd-delete :mark &cmd-mark}
mode-map = %{:c-a &cmd-home :c-e &cmd-end :tab &cmd-indent}
minor-map = %{:insert &cmd-insert-fast :c-l &cmd-recenter}
maps = list minor-map mode-map base-map

defn lookup do
  '() _key -> :nil
  '(m . rest) key -> match (dict-get m key :nil) do
    :nil -> lookup rest key
    handler -> handler
  end
end

defn key-for do
  0 -> :insert
  1 -> :right
  2 -> :insert
  3 -> :left
  4 -> :mark
  5 -> :c-e
  6 -> :delete
  7 -> :c-a
  8 -> :insert
  9 -> :c-l
  10 -> :right
  11 -> :tab
  12 -> :delete
  13 -> :mark
  14 -> :left
  _ -> :insert
end

defn step st key -> match (lookup maps key) do
  :nil -> st
  handler -> handler st
end

defn loop i n st -> if i >= n do
  st
else do
  loop (i + 1) n (step st (key-for (i % 16)))
end

st = loop 0 120000 %{:point 0 :size 0 :marks 0 :dirty 0}
out = ((dict-get st :point 0) + ((dict-get st :size 0) * 3) + ((dict-get st :marks 0) % 1000000007) + ((dict-get st :dirty 0) * 11)) % 1000000007
println out

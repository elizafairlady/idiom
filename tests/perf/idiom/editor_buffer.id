import std/string as Str

defn imin do
  a b when (lt? a b) -> a
  _ b -> b
end

defn imax do
  a b when (gt? a b) -> a
  _ b -> b
end

defn seed i n acc -> if i >= n do
  acc
else do
  seed (i + 1) n "#{acc}line ${i} alpha beta gamma\n"
end

defn checksum s i acc -> if i >= Str.len s do
  acc
else do
  checksum s (i + 1) (((acc * 33) + (Str.byte s i)) % 1000000007)
end

defn insert-at b p text -> "#{Str.slice b 0 p}${text}#{Str.slice b p (Str.len b)}"

defn delete-at b p n do
  e = imin (Str.len b) (p + n)
  "#{Str.slice b 0 p}#{Str.slice b e (Str.len b)}"
end

defn op-pos i len -> ((i * 37) + (i / 7)) % (len + 1)

defn step i {b p} do
  n = Str.len b
  op = i % 8
  match op do
    0 -> do
      b2 = insert-at b p "x"
      {b2 (p + 1)}
    end
    1 -> do
      b2 = insert-at b p "\n"
      {b2 (p + 1)}
    end
    2 -> {b (op-pos i n)}
    3 -> do
      b2 = cond (lt? p n) (delete-at b p 1) b
      {b2 (imin p (Str.len b2))}
    end
    4 -> do
      b2 = insert-at b p "()"
      {b2 (p + 2)}
    end
    5 -> {b (imax 0 (p - (1 + (i % 5))))}
    6 -> do
      b2 = cond (lt? p n) (delete-at b p 3) b
      {b2 (imin p (Str.len b2))}
    end
    _ -> {b (imin n (p + 1 + (i % 7)))}
  end
end

defn loop i n state -> if i >= n do
  state
else do
  loop (i + 1) n (step i state)
end

initial = seed 0 160 ""
{text point} = loop 0 2500 {initial 0}
println (((checksum text 0 0) + ((Str.len text) * 17) + point) % 1000000007)

import std/string as Str

defn imin do
  a b when (lt? a b) -> a
  _ b -> b
end

defn imax do
  a b when (gt? a b) -> a
  _ b -> b
end

defn checksum s i n acc -> if i >= n do
  acc
else do
  checksum s (i + 1) n (((acc * 131) + (Str.byte s i)) % 1000000007)
end

defn line-text i -> "line ${i} :: alpha beta gamma ${i % 17}"

defn render-line row width acc do
  text = line-text row
  n = imin width (Str.len text)
  ((acc * 17) + (checksum text 0 n 0)) % 1000000007
end

defn render-range row stop width acc -> if row >= stop do
  acc
else do
  render-range (row + 1) stop width (render-line row width acc)
end

defn render-state {top _point height width split} acc do
  first-stop = add top (cond (gt? split 0) split height)
  acc1 = render-range top first-stop width acc
  cond (gt? split 0) (render-range (add top split) (add top height) width acc1) acc1
end

defn update-state i {top point height width split} do
  match (i % 10) do
    0 -> {top (imin 999 (point + 1)) height width split}
    1 -> {top (imax 0 (point - 1)) height width split}
    2 -> {(imin 960 (top + 1)) point height width split}
    3 -> {(imax 0 (top - 1)) point height width split}
    4 -> {top point height (40 + (i % 50)) split}
    5 -> {top point (12 + (i % 15)) width split}
    6 -> {top point height width (cond (split == 0) (height / 2) 0)}
    7 -> {point point height width split}
    8 -> {top ((i * 37) % 1000) height width split}
    _ -> {top point height width split}
  end
end

defn loop i n state acc -> if i >= n do
  acc
else do
  next = update-state i state
  loop (i + 1) n next (render-state next acc)
end

println (loop 0 4000 {0 0 24 80 0} 0)

defn classify do
  {0 0 x} -> x + 1
  {0 1 x} -> x + 2
  {0 2 x} -> x + 3
  {0 3 x} -> x + 4
  {0 4 x} -> x + 5
  {0 5 x} -> x + 6
  {0 6 x} -> x + 7
  {0 7 x} -> x + 8
  {1 0 x} -> x + 9
  {1 1 x} -> x + 10
  {1 2 x} -> x + 11
  {1 3 x} -> x + 12
  {1 4 x} -> x + 13
  {1 5 x} -> x + 14
  {1 6 x} -> x + 15
  {1 7 x} -> x + 16
  {2 0 x} -> x + 17
  {2 1 x} -> x + 18
  {2 2 x} -> x + 19
  {2 3 x} -> x + 20
  {2 4 x} -> x + 21
  {2 5 x} -> x + 22
  {2 6 x} -> x + 23
  {2 7 x} -> x + 24
  {3 0 x} -> x + 25
  {3 1 x} -> x + 26
  {3 2 x} -> x + 27
  {3 3 x} -> x + 28
  {3 4 x} -> x + 29
  {3 5 x} -> x + 30
  {3 6 x} -> x + 31
  {3 7 x} -> x + 32
  {4 0 x} -> x + 33
  {4 1 x} -> x + 34
  {4 2 x} -> x + 35
  {4 3 x} -> x + 36
  {4 4 x} -> x + 37
  {4 5 x} -> x + 38
  {4 6 x} -> x + 39
  {4 7 x} -> x + 40
  {5 0 x} -> x + 41
  {5 1 x} -> x + 42
  {5 2 x} -> x + 43
  {5 3 x} -> x + 44
  {5 4 x} -> x + 45
  {5 5 x} -> x + 46
  {5 6 x} -> x + 47
  {5 7 x} -> x + 48
  {6 0 x} -> x + 49
  {6 1 x} -> x + 50
  {6 2 x} -> x + 51
  {6 3 x} -> x + 52
  {6 4 x} -> x + 53
  {6 5 x} -> x + 54
  {6 6 x} -> x + 55
  {6 7 x} -> x + 56
  {7 0 x} -> x + 57
  {7 1 x} -> x + 58
  {7 2 x} -> x + 59
  {7 3 x} -> x + 60
  {7 4 x} -> x + 61
  {7 5 x} -> x + 62
  {7 6 x} -> x + 63
  {7 7 x} -> x + 64
  _ -> 0
end

defn loop i n acc -> if i >= n do acc else do
  a = i % 8
  b = (i / 8) % 8
  loop (i + 1) n ((acc + (classify {a b i})) % 1000000007)
end

println (loop 0 100000 0)

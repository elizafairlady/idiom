use app/ish
import std/string as Str

defn key-for do
  0 -> {:char "a"}
  1 -> {:char "b"}
  2 -> {:char "c"}
  3 -> :left
  4 -> {:char "X"}
  5 -> :right
  6 -> :c-a
  7 -> :c-k
  8 -> :c-y
  9 -> :c-e
  10 -> :c-w
  11 -> :c-y
  12 -> :c-r
  13 -> {:char "g"}
  14 -> :c-r
  15 -> :c-c
  16 -> :up
  17 -> :down
  18 -> :tab
  19 -> :delete
  _ -> :c-u
end

defn checksum s i acc -> if i >= Str.len s do
  acc
else do
  checksum s (i + 1) (((acc * 33) + (Str.byte s i)) % 1000000007)
end

defn first-history state -> match (dict-get state :history '()) do
  '(h . _) -> h
  _ -> ""
end

defn state-score st do
  b = dict-get st :buffer ""
  k = dict-get st :kill ""
  saved = dict-get st :saved ""
  search = dict-get st :search ""
  h = first-history st
  ((checksum b 0 0) + (checksum k 0 0) + (checksum saved 0 0) + (checksum search 0 0) + (checksum h 0 0) + (dict-get st :cursor 0) + (((dict-get st :hist-pos 0) + 1) * 17)) % 1000000007
end

defn run-trace j n state -> if j >= n do
  state
else do
  match (step state (key-for j)) do
    {_tag st} -> run-trace (j + 1) n st
  end
end

defn loop i n state acc -> if i >= n do
  acc
else do
  st = run-trace 0 21 state
  acc2 = (acc + (state-score st)) % 1000000007
  loop (i + 1) n (reset st) acc2
end

start = initial-state "> "
with-history = push-history (push-history (push-history start "grep alpha") "open beta") "goto gamma"
println (loop 0 2500 with-history 0)

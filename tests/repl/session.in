x = 41
defn bump n -> n + 1
bump x
defmacro dbl do
  %`(dbl %,a) -> %`(mul 2 %,a)
end
dbl (bump x)
defn ff n -> add n kaboom
ff 1
defn ff n -> add n 1
ff x
defmacro mm %`(mm %,a) -> %`(dbl %,a)
mm (ff 100)
use app/ish
activate Shell
y = printf from-repl-shell
y
{p q} = tuple 5 6
add p q
{r s} = tuple 7
add r 1
p
counter = spawn (fn do
  defn serve total -> receive do
    {:add n} -> serve (total + n)
    {:get from} -> do
      send from (tuple :total total)
      serve total
    end
  end
  serve 0
end)
send counter (tuple :add 5)
send counter (tuple :add 2)
do
  send counter (tuple :get (self))
  receive do {:total n} -> n end
end
{:ok f tok} = repl-compile "20 + 22"
do
  trap-exit :true
  w = repl-spawn &f
  link w
  receive do {:exit p r} -> r end
end
raise :pinned-diag
repl-diagnostic
repl-diagnostic
inspect (ish-session)
trait Greet do
  method greet x
end
implement Greet on int do
  method greet n -> str "hi-" n
end
greet 7
implement Greet on int do
  method greet n -> str "yo-" n
end
greet 7
